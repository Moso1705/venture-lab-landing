---
/**
 * The waitlist capture as a working funnel: one email field, POSTs to
 * /api/get-in-line, stores in the vl-waitlist blob store. This is the interim
 * answer until the real application forms exist.
 */
interface Props {
  role: 'founder' | 'mba' | 'mentor';
  note: string;
}

const { role, note } = Astro.props;
---

<div class="get-in-line border border-line bg-paper-raised px-6 py-7 md:px-8">
  <p class="font-mono text-[0.75rem] uppercase tracking-[0.18em] text-soot">Spots are limited.</p>
  <p class="mt-2 text-[0.9375rem] leading-relaxed text-soot">{note}</p>
  <form class="gil-form mt-7" data-role={role}>
    <div class="flex flex-wrap items-end gap-x-6 gap-y-5">
      <div class="min-w-[14rem] flex-1">
        <label class="font-mono text-[0.75rem] uppercase tracking-[0.18em] text-gray" for={`gil-email-${role}`}>
          Email
        </label>
        <input
          id={`gil-email-${role}`}
          type="email"
          name="email"
          required
          maxlength="254"
          placeholder="ada@lovelace.dev"
          autocomplete="email"
          class="mt-2 block w-full border-b border-gray bg-transparent pb-2 text-[1.0625rem] text-ink placeholder:text-faint focus:border-ink focus:outline-none"
        />
      </div>
      <input type="text" name="company_website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
      <button type="submit" class="btn-ink">Get in line</button>
    </div>
  </form>
  <p class="gil-status mt-5 hidden font-mono text-[0.8125rem]" role="status" aria-live="polite"></p>
  <p class="mt-5 font-mono text-[0.75rem] tracking-[0.04em] text-gray">
    email is only used to tell you when applications open
  </p>
</div>

<script>
  document.querySelectorAll<HTMLFormElement>('.gil-form').forEach((form) => {
    const box = form.closest('.get-in-line')!;
    const status = box.querySelector('.gil-status') as HTMLElement;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form).entries());
      status.classList.remove('hidden');
      status.textContent = '… writing you into the ledger';
      status.style.color = 'var(--color-gray)';
      try {
        const res = await fetch('/api/get-in-line', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...data, role: form.dataset.role }),
        });
        const out = await res.json();
        if (out.ok) {
          form.classList.add('hidden');
          status.textContent = '✓ you are in line. we write the moment selection opens.';
          status.style.color = 'var(--color-phoenix)';
        } else {
          status.textContent = `✗ ${out.error ?? 'could not save, try again'}`;
          status.style.color = 'var(--color-soot)';
        }
      } catch {
        status.textContent = '✗ network hiccup, try again';
        status.style.color = 'var(--color-soot)';
      }
    });
  });
</script>
