---
/**
 * Email capture until the real application form exists.
 * API route name stays /api/get-in-line; user-facing copy does not.
 */
interface Props {
  role: 'founder' | 'mba' | 'mentor';
  note?: string;
  cta?: string;
  finePrint?: string;
  showNote?: boolean;
}

const {
  role,
  note,
  cta = 'Notify me',
  finePrint = 'Email is only used to tell you when applications open.',
  showNote = false,
} = Astro.props;
---

<div class="get-in-line soft-card p-6 md:p-8">
  {showNote && note && <p class="mb-6 text-[0.9375rem] leading-relaxed text-soot">{note}</p>}
  <form class="gil-form" data-role={role}>
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end">
      <div class="min-w-0 flex-1">
        <label class="text-xs font-medium uppercase tracking-[0.12em] text-gray" for={`gil-email-${role}`}>
          Email
        </label>
        <input
          id={`gil-email-${role}`}
          type="email"
          name="email"
          required
          maxlength="254"
          placeholder="you@company.com"
          autocomplete="email"
          class="mt-2 block w-full rounded-xl border border-line bg-paper-raised/50 px-4 py-3 text-[1.0625rem] text-ink placeholder:text-faint focus:border-ink focus:bg-paper focus:outline-none"
        />
      </div>
      <input type="text" name="company_website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
      <button type="submit" class="btn-ink shrink-0 sm:mb-0.5">{cta}</button>
    </div>
  </form>
  <p class="gil-status mt-5 hidden text-sm" role="status" aria-live="polite"></p>
  <p class="mt-4 text-xs text-gray">{finePrint}</p>
</div>

<script>
  document.querySelectorAll<HTMLFormElement>('.gil-form').forEach((form) => {
    const box = form.closest('.get-in-line')!;
    const status = box.querySelector('.gil-status') as HTMLElement;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form).entries());
      status.classList.remove('hidden');
      status.textContent = 'Saving…';
      status.style.color = 'var(--color-gray)';
      try {
        const res = await fetch('/api/get-in-line', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ...data, role: form.dataset.role }),
        });
        const out = await res.json();
        if (out.ok) {
          form.classList.add('hidden');
          status.textContent = 'Saved. We will write when applications open.';
          status.style.color = 'var(--color-ink)';
        } else {
          status.textContent = out.error ?? 'Could not save. Try again.';
          status.style.color = 'var(--color-soot)';
        }
      } catch {
        status.textContent = 'Network error. Try again.';
        status.style.color = 'var(--color-soot)';
      }
    });
  });
</script>
