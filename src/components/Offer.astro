---
import { offer } from '../content/site';
import SectionHead from './SectionHead.astro';
---

<section>
  <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
    <SectionHead index="02" label={offer.eyebrow.replace(/^\/\s*/, '')} annotation="three layers of support">
      <h2 class="mt-10 max-w-2xl font-display text-3xl leading-tight text-paper md:text-4xl">
        {offer.headline.lead} {offer.headline.emphasis}
      </h2>
    </SectionHead>

    <div class="mt-14">
      {
        offer.pillars.map((pillar) => (
          <div class="reveal grid gap-4 border-t border-line py-10 last:border-b md:grid-cols-[1fr_1.2fr] md:gap-12">
            <h3 class="font-display text-3xl leading-tight text-paper md:text-4xl">{pillar.title}</h3>
            <p class="max-w-prose text-base leading-relaxed text-fog md:text-lg">{pillar.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
