---
/**
 * What you get, as a plain list with bold lead-ins, HN12-style. The partner
 * row sits at the bottom of the same section: names we can show, no more.
 */
import { offer } from '../content/site';
---

<section class="border-t border-line">
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
    <div class="md:grid md:grid-cols-[16rem_minmax(0,1fr)] md:gap-16">
      <p class="marker reveal">{offer.marker}</p>
      <div class="mt-8 max-w-2xl md:mt-0">
        <h2 class="display reveal text-[clamp(2.25rem,4.5vw,3.5rem)]">{offer.headline}</h2>
        <ul class="mt-12 space-y-9">
          {
            offer.items.map((item) => (
              <li class="reveal flex gap-5">
                <span class="mt-3 h-1 w-1 shrink-0 rounded-full bg-ink" aria-hidden="true" />
                <p class="text-[1.0625rem] leading-relaxed text-gray">
                  <strong class="font-medium text-ink">{item.lead}</strong> {item.body}
                </p>
              </li>
            ))
          }
        </ul>

        <div class="reveal mt-16 border-t border-line pt-8">
          <p class="font-mono text-[0.75rem] uppercase tracking-[0.18em] text-gray">{offer.partners.line}</p>
          <div class="mt-6 flex flex-wrap items-center gap-x-12 gap-y-6 text-soot">
            {
              offer.partners.orgs.map((org) => (
                <a href={org.href} rel="noopener" target="_blank" class="transition-opacity hover:opacity-70" aria-label={org.name}>
                  <img src={org.logo} alt={org.name} height={org.h} style={`height:${org.h}px`} class="w-auto" loading="lazy" />
                </a>
              ))
            }
          </div>
          <p class="mt-6 text-[0.9375rem] leading-relaxed text-gray">{offer.partners.schools}</p>
          <p class="mt-2 text-[0.9375rem] leading-relaxed text-gray">{offer.partners.ewor}</p>
        </div>
      </div>
    </div>
  </div>
</section>
