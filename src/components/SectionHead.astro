---
/**
 * The section-header grammar of the measured page. Two modes, alternated:
 * - index: full-width hairline, mono index + label left, annotation right,
 *   optional modest headline. Reads like a technical document row.
 * - statement: mono index beside a massive serif statement.
 */
interface Props {
  index: string;
  label: string;
  annotation?: string;
  mode?: 'index' | 'statement';
  onPaper?: boolean;
}

const { index, label, annotation, mode = 'index', onPaper = false } = Astro.props;
const lineColor = onPaper ? 'border-paper-line' : 'border-line';
const labelColor = onPaper ? 'text-soot' : 'text-fog-dim';
const accent = onPaper ? 'text-phoenix' : 'text-phoenix-bright';
---

{
  mode === 'index' ? (
    <div class:list={['reveal border-t', lineColor]}>
      <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1 pt-3">
        <p class="font-mono text-[0.8125rem] tracking-[0.08em]">
          <span class:list={['font-medium', accent]}>{index}</span>
          <span class:list={['ml-3 lowercase', labelColor]}>{label}</span>
        </p>
        {annotation && (
          <p class:list={['font-mono text-[0.75rem] tracking-[0.08em] lowercase', labelColor]}>{annotation}</p>
        )}
      </div>
      <slot />
    </div>
  ) : (
    <div class="reveal">
      <p class="font-mono text-[0.8125rem] tracking-[0.08em]">
        <span class:list={['font-medium', accent]}>{index}</span>
        <span class:list={['ml-3 lowercase', labelColor]}>{label}</span>
        {annotation && <span class:list={['ml-6 hidden lowercase md:inline', labelColor]}>{annotation}</span>}
      </p>
      <slot />
    </div>
  )
}
