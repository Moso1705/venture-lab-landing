---
import { hero } from '../content/site';
---

<!-- Mobile-only apply bar that slides in once the hero is scrolled past.
     Pure CSS scroll-driven animation: browsers without support never show it,
     which is fine because the same CTA exists in nav, hero, and apply. -->
<a href="#apply" class="sticky-apply fixed inset-x-0 bottom-0 z-50 bg-phoenix py-4 pb-[max(1rem,env(safe-area-inset-bottom))] text-center font-sans text-base font-semibold text-ink md:hidden">
  {hero.primaryCta.label}
</a>

<style>
  .sticky-apply {
    display: none;
  }
  @supports (animation-timeline: scroll()) {
    @media (prefers-reduced-motion: no-preference) {
      .sticky-apply {
        display: block;
        transform: translateY(100%);
        animation: sticky-apply-in 1ms linear both;
        animation-timeline: scroll();
        animation-range: 0 100vh;
      }
    }
  }
  @keyframes sticky-apply-in {
    from {
      transform: translateY(100%);
    }
    to {
      transform: translateY(0);
    }
  }
</style>
