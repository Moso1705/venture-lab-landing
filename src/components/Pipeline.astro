---
import { pipeline } from '../content/site';
import SectionHead from './SectionHead.astro';
---

<section class="border-t border-line">
  <div class="mx-auto max-w-6xl px-6 pt-28 pb-16 md:pt-36 md:pb-20">
    <SectionHead index="01" label={pipeline.eyebrow.replace(/^\/\s*/, '')} mode="statement">
      <h2 class="mt-6 max-w-3xl font-display text-[clamp(2.5rem,5.5vw,4.5rem)] leading-[1.0] tracking-[-0.01em] text-paper">
        {pipeline.headline.lead} {pipeline.headline.emphasis}
      </h2>
    </SectionHead>

    <ol class="mt-16 grid gap-10 md:grid-cols-4 md:gap-6">
      {
        pipeline.steps.map((step) => (
          <li class="reveal relative border-t border-line pt-5">
            <span class="absolute -top-px left-0 h-px w-10 bg-phoenix" />
            <span class="font-mono text-[0.75rem] tracking-[0.08em] text-phoenix-bright">{step.num}</span>
            <h3 class="mt-3 font-display text-3xl text-paper">{step.title}</h3>
            <p class="mt-3 text-[0.9375rem] leading-relaxed text-fog">{step.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
