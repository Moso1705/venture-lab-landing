---
/**
 * The signature section: the trajectory chart. A prototype line goes flat,
 * the Lab bends it exponential over twelve weeks, and past Investor Day the
 * curve branches into the seed round. The six program phases and the gate
 * read as the mechanics under the chart.
 */
import { jump } from '../content/site';

// Desktop chart geometry (viewBox 1120 x 460).
const X0 = 170;   // wk00
const X12 = 880;  // wk12
const ticks = jump.chart.axis.map((label, i) => ({
  label,
  x: X0 + ((X12 - X0) / (jump.chart.axis.length - 1)) * i,
}));
const GATE_X = ticks[5].x; // wk10
---

<section id="program" class="border-t border-line">
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
    <p class="marker reveal text-center">{jump.marker}</p>
    <h2 class="display reveal mx-auto mt-6 max-w-4xl text-center text-[clamp(2.5rem,5.5vw,4.25rem)]">
      <span class="text-faint">{jump.headline.lead}</span><br />
      <span>{jump.headline.emphasis}</span>
    </h2>
    <p class="reveal mx-auto mt-6 max-w-2xl text-center text-[1.0625rem] leading-relaxed text-gray">
      {jump.sub}
    </p>

    <!-- The chart. Desktop version. -->
    <div class="chart-wrap relative mt-16 hidden md:block" role="img" aria-label="Chart: a prototype line stays flat until the Lab starts, rises steeply across the twelve program weeks, and branches upward into your seed round after Investor Day.">
      <svg viewBox="0 0 1160 460" class="w-full" aria-hidden="true">
        <!-- vertical week grid -->
        {ticks.map((t) => <line x1={t.x} y1="40" x2={t.x} y2="400" stroke="var(--color-line)" stroke-width="1" />)}

        <!-- axis ruler -->
        <line x1="40" y1="400" x2="1120" y2="400" stroke="var(--color-line)" stroke-width="1" />
        {ticks.map((t) => (
          <>
            <line x1={t.x} y1="400" x2={t.x} y2="408" stroke="var(--color-gray)" stroke-width="1" />
            <text x={t.x} y="430" text-anchor="middle" fill="var(--color-gray)" font-family="var(--font-mono)" font-size="12" letter-spacing="1.5">
              {t.label}
            </text>
          </>
        ))}

        <!-- the prototype before the lab: built in 24 hours, then flat -->
        <path d="M40 372 L96 372 L118 352 L170 348" fill="none" stroke="var(--color-gray)" stroke-width="1.5" />
        <text x="42" y="330" fill="var(--color-gray)" font-family="var(--font-mono)" font-size="12" letter-spacing="1.5">
          {jump.chart.startLabel}
        </text>

        <!-- the counterfactual: left alone, a demo stays a demo -->
        <line x1="170" y1="348" x2="1078" y2="344" stroke="var(--color-faint)" stroke-width="1" stroke-dasharray="2 6" />
        <text x="1078" y="332" text-anchor="end" fill="var(--color-faint)" font-family="var(--font-mono)" font-size="11" letter-spacing="1.5">
          the prototype, left alone
        </text>

        <!-- the jump: twelve weeks bending the line exponential -->
        <path
          d="M170 348 C420 345 640 320 780 245 C855 205 866 150 880 90"
          fill="none"
          stroke="var(--color-ink)"
          stroke-width="2"
        />

        <!-- gate marker before the finale -->
        <line x1={GATE_X} y1="180" x2={GATE_X} y2="400" stroke="var(--color-gray)" stroke-width="1" stroke-dasharray="3 5" />
        <text x={GATE_X} y="166" text-anchor="middle" fill="var(--color-gray)" font-family="var(--font-mono)" font-size="12" letter-spacing="1.5">
          the gate
        </text>

        <!-- milestones on the curve -->
        <circle cx="170" cy="348" r="4" fill="var(--color-ink)" />
        <text x="182" y="374" fill="var(--color-soot)" font-family="var(--font-mono)" font-size="12" letter-spacing="1.5">
          the lab starts
        </text>
        <circle cx="560" cy="316" r="4" fill="var(--color-ink)" />
        <text x="560" y="292" text-anchor="middle" fill="var(--color-soot)" font-family="var(--font-mono)" font-size="12" letter-spacing="1.5">
          demo day
        </text>
        <circle cx="880" cy="90" r="4.5" fill="var(--color-phoenix)" />
        <text x="866" y="82" text-anchor="end" fill="var(--color-ink)" font-family="var(--font-mono)" font-size="12" letter-spacing="1.5">
          {jump.chart.endLabel}
        </text>

        <!-- past wk12: the branch you are here for -->
        <line x1="880" y1="90" x2="1000" y2="32" stroke="var(--color-phoenix)" stroke-width="2" stroke-dasharray="6 6" />
        <circle cx="1000" cy="32" r="4" fill="none" stroke="var(--color-phoenix)" stroke-width="2" />
        <text x="1014" y="37" fill="var(--color-phoenix)" font-family="var(--font-mono)" font-size="12" letter-spacing="1.5">
          {jump.chart.branchLabel}
        </text>
      </svg>
      <div class="chart-wipe" aria-hidden="true"></div>
    </div>

    <!-- Compact chart for small screens: same story, fewer labels. -->
    <div class="chart-wrap relative mt-12 md:hidden" role="img" aria-label="Chart: a prototype line stays flat until the Lab starts, rises steeply across the twelve program weeks, and branches upward into your seed round after Investor Day.">
      <svg viewBox="0 0 390 290" class="w-full" aria-hidden="true">
        {[70, 185, 300].map((x) => <line x1={x} y1="30" x2={x} y2="240" stroke="var(--color-line)" stroke-width="1" />)}
        <line x1="12" y1="240" x2="378" y2="240" stroke="var(--color-line)" stroke-width="1" />
        {[
          { x: 70, label: 'wk00' },
          { x: 185, label: 'wk06' },
          { x: 300, label: 'wk12' },
        ].map((t) => (
          <>
            <line x1={t.x} y1="240" x2={t.x} y2="246" stroke="var(--color-gray)" stroke-width="1" />
            <text x={t.x} y="264" text-anchor="middle" fill="var(--color-gray)" font-family="var(--font-mono)" font-size="11" letter-spacing="1">
              {t.label}
            </text>
          </>
        ))}
        <path d="M12 216 L38 216 L48 206 L70 204" fill="none" stroke="var(--color-gray)" stroke-width="1.5" />
        <text x="14" y="196" fill="var(--color-gray)" font-family="var(--font-mono)" font-size="11" letter-spacing="1">
          {jump.chart.startLabel}
        </text>
        <path d="M70 204 C160 202 230 180 262 140 C284 112 300 84 300 62" fill="none" stroke="var(--color-ink)" stroke-width="2" />
        <circle cx="70" cy="204" r="3.5" fill="var(--color-ink)" />
        <circle cx="300" cy="62" r="4" fill="var(--color-phoenix)" />
        <text x="288" y="54" text-anchor="end" fill="var(--color-ink)" font-family="var(--font-mono)" font-size="11" letter-spacing="1">
          investor day
        </text>
        <line x1="300" y1="62" x2="352" y2="30" stroke="var(--color-phoenix)" stroke-width="2" stroke-dasharray="5 5" />
        <circle cx="352" cy="30" r="3.5" fill="none" stroke="var(--color-phoenix)" stroke-width="2" />
        <text x="344" y="18" text-anchor="end" fill="var(--color-phoenix)" font-family="var(--font-mono)" font-size="11" letter-spacing="1">
          {jump.chart.branchLabel}
        </text>
      </svg>
      <div class="chart-wipe" aria-hidden="true"></div>
    </div>

    <!-- The mechanics: six phases, two weeks each. -->
    <div class="mt-16 grid gap-x-10 gap-y-10 sm:grid-cols-2 md:mt-20 md:grid-cols-3">
      {
        jump.phases.map((phase) => (
          <div class="reveal border-t border-line pt-5">
            <p class="font-mono text-[0.75rem] uppercase tracking-[0.18em] text-gray">{phase.weeks}</p>
            <h3 class="mt-2.5 text-lg font-medium">{phase.title}</h3>
            <p class="mt-2 text-[0.9375rem] leading-relaxed text-gray">{phase.body}</p>
          </div>
        ))
      }
    </div>

    <div class="reveal mt-14 border border-line border-l-2 border-l-phoenix bg-paper-raised px-6 py-5 md:px-8">
      <p class="font-mono text-[0.75rem] uppercase tracking-[0.18em] text-soot">{jump.gate.title}</p>
      <p class="mt-2 max-w-3xl text-[0.9375rem] leading-relaxed text-soot">{jump.gate.body}</p>
    </div>
  </div>
</section>

<style>
  /* The chart draws itself in as it scrolls into view: a paper overlay slides
     off to the right. Transform-only; without support or with reduced motion
     the overlay never shows. */
  .chart-wipe {
    display: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      .chart-wipe {
        display: block;
        position: absolute;
        inset: 0;
        background: var(--color-paper);
        transform-origin: right;
        animation: chart-wipe-out 1ms linear both;
        animation-timeline: view();
        animation-range: entry 20% entry 90%;
      }
      @keyframes chart-wipe-out {
        from {
          transform: scaleX(1);
        }
        to {
          transform: scaleX(0);
        }
      }
    }
  }
</style>
