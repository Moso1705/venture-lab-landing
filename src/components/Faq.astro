---
/**
 * FAQ as quiet accordion rows, HN12-style: mono questions, hairlines, a
 * plus that turns into a cross. Native details/summary, no JS.
 */
import { faq } from '../content/site';
---

<section id="faq" class="border-t border-line">
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-28">
    <p class="marker reveal">{faq.marker}</p>
    <div class="mt-10 border-t border-line">
      {
        faq.items.map((item) => (
          <details class="reveal group border-b border-line">
            <summary class="flex cursor-pointer list-none items-baseline justify-between gap-6 py-6 [&::-webkit-details-marker]:hidden">
              <span class="font-mono text-[0.9375rem] uppercase tracking-[0.14em] text-ink transition-colors group-hover:text-phoenix">
                {item.q}
              </span>
              <span
                class="shrink-0 font-mono text-xl text-gray transition-transform duration-200 group-open:rotate-45"
                aria-hidden="true"
              >
                +
              </span>
            </summary>
            <p class="faq-answer max-w-2xl pb-7 text-[1.0625rem] leading-relaxed text-gray">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: no-preference) {
    details[open] .faq-answer {
      animation: faq-in 0.35s var(--ease-out-quart) both;
    }
    @keyframes faq-in {
      from {
        opacity: 0;
        transform: translateY(-6px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }
</style>
