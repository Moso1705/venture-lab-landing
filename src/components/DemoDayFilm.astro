---
import { demoDayVideoUrl, film } from '../content/site';

// Renders nothing until Michi drops a video URL into site.ts.
const isEmbed = /youtube\.com|youtu\.be|vimeo\.com/.test(demoDayVideoUrl);
const embedSrc = demoDayVideoUrl
  .replace(/watch\?v=/, 'embed/')
  .replace(/youtu\.be\//, 'www.youtube.com/embed/')
  .replace(/vimeo\.com\//, 'player.vimeo.com/video/');
---

{
  demoDayVideoUrl && (
    <section class="border-t border-line">
      <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
        <div class="reveal">
          <p class="marker">{film.marker}</p>
          <h2 class="display mt-6 max-w-3xl text-[clamp(2.25rem,4.5vw,3.5rem)]">{film.headline}</h2>
        </div>
        <div class="reveal mt-12 border border-line">
          {isEmbed ? (
            <iframe
              src={embedSrc}
              title="Venture Lab Investor Day"
              loading="lazy"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              class="aspect-video w-full bg-ink"
            />
          ) : (
            <video
              src={demoDayVideoUrl}
              class="aspect-video w-full bg-ink object-cover"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
            />
          )}
        </div>
      </div>
    </section>
  )
}
