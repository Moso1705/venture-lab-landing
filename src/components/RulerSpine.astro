---
/**
 * The ruler promoted to page spine: a fixed tick rail on the left edge whose
 * orange fill tracks scroll progress. Pure CSS scroll-driven animation;
 * browsers without support (or reduced motion) never see it, desktop only.
 */
---

<div class="ruler-spine fixed top-1/2 left-5 z-40 hidden -translate-y-1/2 xl:block" aria-hidden="true">
  <span class="mb-2 block text-center font-mono text-[0.625rem] tracking-[0.08em] text-fog-dim">h00</span>
  <div class="spine-track relative h-[46vh] w-4">
    <div class="spine-fill absolute inset-x-0 top-0 origin-top bg-phoenix"></div>
  </div>
  <span class="mt-2 block text-center font-mono text-[0.625rem] tracking-[0.08em] text-fog-dim">wk12</span>
</div>

<style>
  .ruler-spine {
    display: none;
  }
  @media (width >= 80rem) {
    @supports (animation-timeline: scroll()) {
      @media (prefers-reduced-motion: no-preference) {
        .ruler-spine {
          display: block;
        }
      }
    }
  }
  .spine-fill {
    width: 2px;
    left: 50%;
    margin-left: -1px;
    height: 100%;
    transform: scaleY(0);
    animation: spine-progress 1ms linear both;
    animation-timeline: scroll(root);
  }
  @keyframes spine-progress {
    from {
      transform: scaleY(0);
    }
    to {
      transform: scaleY(1);
    }
  }
</style>
