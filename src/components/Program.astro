---
import { program } from '../content/site';
---

<section id="program" class="bg-paper text-ink">
  <div class="mx-auto max-w-6xl px-6 py-28 md:py-40">
    <div class="reveal">
      <p class="font-mono text-[0.8125rem] tracking-[0.08em]">
        <span class="font-medium text-phoenix">04</span>
        <span class="ml-3 lowercase text-soot">{program.eyebrow.replace(/^\/\s*/, '')}</span>
      </p>
      <h2 class="mt-6 font-display text-[clamp(2.5rem,6vw,5rem)] leading-[0.98] tracking-[-0.01em]">
        {program.headline.lead} <em>{program.headline.emphasis}</em>
      </h2>
      <p class="mt-7 max-w-2xl text-lg leading-relaxed text-soot">{program.intro}</p>
    </div>

    <ol class="mt-16 border-t border-paper-line">
      {
        program.phases.map((phase) => (
          <li class="reveal grid gap-2 border-b border-paper-line py-6 md:grid-cols-[10rem_16rem_1fr] md:gap-8 md:py-7">
            <span class="font-mono text-[0.8125rem] font-medium tracking-[0.08em] text-phoenix">{phase.weeks}</span>
            <h3 class="font-display text-2xl leading-tight">{phase.title}</h3>
            <p class="max-w-prose text-[0.9375rem] leading-relaxed text-soot">{phase.body}</p>
          </li>
        ))
      }
    </ol>

    <aside class="reveal mt-14 border-l-4 border-phoenix bg-ink px-8 py-9 text-paper md:px-10">
      <div class="flex items-baseline justify-between gap-4">
        <p class="font-mono text-[0.75rem] tracking-[0.08em] text-phoenix-bright">/ the stage gate</p>
        <p class="hidden font-mono text-[0.6875rem] tracking-[0.08em] text-fog-dim md:block"><span class="text-phoenix-bright">fig. 02</span> — what free costs</p>
      </div>
      <p class="mt-4 max-w-3xl font-display text-3xl leading-snug md:text-4xl">
        {program.gate.body}
      </p>
    </aside>
  </div>
</section>
