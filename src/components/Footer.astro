---
import { footer } from '../content/site';
---

<footer class="border-t border-line bg-paper">
  <div class="mx-auto flex max-w-6xl flex-col gap-8 px-6 py-14 md:flex-row md:items-end md:justify-between md:px-8">
    <div>
      <p class="font-serif text-2xl text-ink">{footer.wordmark}</p>
      <p class="mt-3 text-sm text-gray">{footer.line}</p>
      <p class="mt-1.5 text-xs text-faint">{footer.legal}</p>
    </div>
    <nav class="flex flex-wrap gap-x-6 gap-y-3" aria-label="Related sites">
      {
        footer.links.map((link) => (
          <a
            href={link.href}
            class="text-sm text-gray underline-offset-4 transition-colors hover:text-ink hover:underline"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</footer>
