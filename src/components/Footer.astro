---
import { footer } from '../content/site';
---

<footer class="border-t border-line">
  <div class="mx-auto flex max-w-6xl flex-col gap-6 px-6 py-12 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="font-sans text-[0.9375rem] font-bold tracking-tight text-paper">
        {footer.wordmark.split(' / ')[0]}
        <span class="font-mono text-[0.8125rem] font-normal text-phoenix-bright"> / {footer.wordmark.split(' / ')[1]}</span>
      </p>
      <p class="mt-3 text-sm text-fog">{footer.line}</p>
      <p class="mt-1 font-mono text-[0.75rem] text-fog-dim">{footer.legal}</p>
    </div>
    <nav class="flex gap-6" aria-label="Related sites">
      {
        footer.links.map((link) => (
          <a
            href={link.href}
            class="font-mono text-[0.8125rem] tracking-[0.08em] text-fog underline-offset-4 transition-colors hover:text-paper hover:underline"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</footer>
