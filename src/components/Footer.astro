---
import { footer } from '../content/site';
---

<footer class="border-t border-line">
  <div class="mx-auto flex max-w-6xl flex-col gap-8 px-6 py-14 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="font-sans text-lg font-extralight uppercase tracking-[0.06em] text-ink">{footer.wordmark}</p>
      <p class="mt-3 text-[0.9375rem] text-gray">{footer.line}</p>
      <p class="mt-1.5 font-mono text-[0.75rem] tracking-[0.04em] text-faint">{footer.legal}</p>
    </div>
    <nav class="flex flex-wrap gap-x-7 gap-y-3" aria-label="Related sites">
      {
        footer.links.map((link) => (
          <a
            href={link.href}
            class="font-mono text-[0.8125rem] tracking-[0.08em] text-gray underline-offset-4 transition-colors hover:text-ink hover:underline"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</footer>
