---
/**
 * The opening moment: the wordmark appears while a counter runs the whole
 * program, wk00 to wk12, over a filling tick strip. Then the curtain lifts
 * into the hero. Plays once per session, any input skips it, reduced motion
 * never sees it, and without JS the overlay never appears at all.
 */
---

<div id="intro" class="intro-overlay" hidden aria-hidden="true">
  <div class="w-[min(34rem,84vw)]">
    <p class="intro-wordmark font-sans text-[clamp(2.75rem,8vw,4.5rem)] font-extralight uppercase leading-none tracking-[0.04em] text-paper">
      Venture Lab
    </p>
    <div class="intro-track relative mt-8 h-2.5">
      <div class="intro-fill absolute inset-y-0 left-0 w-full origin-left bg-paper"></div>
    </div>
    <div class="mt-4 flex items-baseline justify-between font-mono text-[0.75rem] uppercase tracking-[0.18em] text-fog-dim">
      <span class="intro-counter tabular-nums text-fog">wk00</span>
      <span>cohort 3</span>
    </div>
  </div>
</div>

<style>
  .intro-overlay {
    position: fixed;
    inset: 0;
    z-index: 70;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-ink);
    transition: transform 0.65s var(--ease-out-quart);
  }
  .intro-overlay.exit {
    transform: translateY(-100%);
  }
  .intro-track {
    background-image: repeating-linear-gradient(
      to right,
      color-mix(in srgb, var(--color-paper) 24%, transparent) 0 1px,
      transparent 1px 9px
    );
  }
  .intro-fill {
    transform: scaleX(var(--p, 0));
  }
  .intro-wordmark {
    opacity: 0;
    transform: translateY(10px);
    animation: intro-word-in 0.7s var(--ease-out-quart) 0.05s forwards;
  }
  @keyframes intro-word-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  /* Hero choreography waits behind the curtain and plays on reveal. */
  :global(html.intro-hold .hero-enter) {
    animation-play-state: paused;
  }
</style>

<script>
  const overlay = document.getElementById('intro');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const seen = sessionStorage.getItem('vl-intro') === '1';

  if (overlay && !reduced && !seen) {
    const html = document.documentElement;
    const counter = overlay.querySelector('.intro-counter') as HTMLElement;
    const fill = overlay.querySelector('.intro-fill') as HTMLElement;
    html.classList.add('intro-hold');
    overlay.hidden = false;

    let finished = false;
    const finish = () => {
      if (finished) return;
      finished = true;
      sessionStorage.setItem('vl-intro', '1');
      overlay.classList.add('exit');
      html.classList.remove('intro-hold');
      overlay.addEventListener('transitionend', () => overlay.remove(), { once: true });
      // safety: remove even if transitionend never fires
      setTimeout(() => overlay.isConnected && overlay.remove(), 900);
    };

    const DURATION = 1250;
    const WEEKS = 12;
    const start = performance.now();
    const tick = (now: number) => {
      if (finished) return;
      const t = Math.min((now - start) / DURATION, 1);
      const eased = t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
      const week = Math.round(WEEKS * eased);
      counter.textContent = `wk${String(week).padStart(2, '0')}`;
      fill.style.setProperty('--p', String(eased));
      if (t < 1) requestAnimationFrame(tick);
      else setTimeout(finish, 260);
    };
    requestAnimationFrame(tick);

    ['pointerdown', 'keydown', 'wheel', 'touchstart'].forEach((event) =>
      window.addEventListener(event, finish, { once: true, passive: true })
    );
  } else if (overlay) {
    overlay.remove();
  }
</script>
