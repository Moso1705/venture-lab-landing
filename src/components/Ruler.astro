---
/**
 * Signature element: a time ruler. The hackathon is 48 dense hours (orange
 * segment), the Lab is 12 wide weeks. The tick pattern is pure CSS.
 */
---

<div class="relative select-none overflow-hidden border-y border-line" aria-hidden="true">
  <div class="runner-rail pointer-events-none absolute inset-y-0 left-0 w-full">
    <span class="runner absolute inset-y-0 left-0 w-10"></span>
  </div>
  <div class="mx-auto flex max-w-6xl items-stretch px-6">
    <div class="ruler-ticks-dense relative h-14 w-[22%] min-w-28 border-x border-line">
      <span class="absolute top-2 left-2 font-mono text-[0.6875rem] tracking-[0.08em] text-phoenix-bright"
        >h00-h24</span
      >
      <span class="absolute bottom-2 left-2 font-mono text-[0.6875rem] tracking-[0.08em] text-fog-dim"
        >the hackathon</span
      >
    </div>
    <div class="ruler-ticks-wide relative h-14 flex-1 border-r border-line">
      <span class="absolute top-2 left-3 font-mono text-[0.6875rem] tracking-[0.08em] text-paper">wk01</span>
      <span class="absolute top-2 right-3 font-mono text-[0.6875rem] tracking-[0.08em] text-paper">wk12</span>
      <span class="absolute bottom-2 left-3 font-mono text-[0.6875rem] tracking-[0.08em] text-fog-dim"
        >the venture lab</span
      >
    </div>
  </div>
</div>

<style>
  /* Ticks draw in left-to-right on load: a curtain collapses toward the right. */
  .ruler-ticks-dense::after,
  .ruler-ticks-wide::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-ink);
    transform-origin: right;
    animation: ruler-curtain 0.9s var(--ease-out-quart) 0.5s both;
  }
  .ruler-ticks-wide::after {
    animation-delay: 0.8s;
    animation-duration: 1.1s;
  }
  @keyframes ruler-curtain {
    from {
      transform: scaleX(1);
    }
    to {
      transform: scaleX(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ruler-ticks-dense::after,
    .ruler-ticks-wide::after {
      display: none;
    }
  }

  /* A slow scan across the timeline: time moving from hackathon into the Lab. */
  .runner {
    background: linear-gradient(
      to right,
      transparent,
      color-mix(in srgb, var(--color-phoenix-bright) 16%, transparent) 70%,
      color-mix(in srgb, var(--color-phoenix-bright) 75%, transparent)
    );
  }
  @media (prefers-reduced-motion: no-preference) {
    .runner-rail {
      will-change: transform;
      animation: ruler-run 16s linear infinite;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .runner-rail {
      display: none;
    }
  }
  @keyframes ruler-run {
    from {
      transform: translateX(-3.5rem);
    }
    to {
      transform: translateX(100%);
    }
  }

  .ruler-ticks-dense {
    background-image: repeating-linear-gradient(
      to right,
      color-mix(in srgb, var(--color-phoenix) 55%, transparent) 0 1px,
      transparent 1px 7px
    );
    background-size: 100% 10px;
    background-position: center;
    background-repeat: no-repeat;
  }
  .ruler-ticks-wide {
    background-image: repeating-linear-gradient(
      to right,
      color-mix(in srgb, var(--color-paper) 28%, transparent) 0 1px,
      transparent 1px 28px
    );
    background-size: 100% 10px;
    background-position: center;
    background-repeat: no-repeat;
  }
</style>
