---
import Footer from './Footer.astro';

interface RoleData {
  eyebrow: string;
  headline: { lead: string; emphasis: string };
  sub: string;
  telemetry: string[];
  cta: string;
  why: { eyebrow: string; items: { title: string; body: string }[] };
  work: { eyebrow: string; items: { title: string; body: string }[] };
  bar: { eyebrow: string; items: string[] };
  proof: { value: number; suffix: string; label: string }[];
  faq: { q: string; a: string }[];
  apply: { headline: { lead: string; emphasis: string }; sub: string };
}

interface Props {
  data: RoleData;
  formUrl: string;
  formTitle: string;
}

const { data, formUrl, formTitle } = Astro.props;
---

<div class="grain">
  <header class="sticky top-0 z-50 border-b border-line bg-ink/90 backdrop-blur-sm">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3.5">
      <a href="/" class="flex items-baseline gap-2">
        <span class="font-sans text-[0.9375rem] font-bold tracking-tight text-paper">HACKNATION</span>
        <span class="font-mono text-[0.8125rem] text-phoenix-bright">/ venture lab</span>
      </a>
      <nav class="flex items-center gap-7" aria-label="Page">
        <a href="/" class="hidden font-mono text-[0.8125rem] lowercase tracking-[0.08em] text-fog transition-colors hover:text-paper md:block">
          the program
        </a>
        <a href="#apply" class="bg-paper px-5 py-2 font-sans text-sm font-semibold text-ink transition-colors hover:bg-phoenix-bright">
          Apply
        </a>
      </nav>
    </div>
  </header>

  <main>
    <section class="grid-texture relative overflow-hidden">
      <div class="relative mx-auto max-w-6xl px-6 pt-20 pb-20 md:pt-28">
        <aside class="absolute top-24 right-6 hidden border border-line bg-ink-raised/80 px-5 py-4 lg:block" aria-label="Role at a glance">
          {
            data.telemetry.map((line, i) => (
              <p class:list={['font-mono text-[0.75rem] leading-loose tracking-[0.08em]', i === 0 ? 'text-phoenix-bright' : 'text-fog']}>
                {line}
              </p>
            ))
          }
        </aside>
        <p class="eyebrow">{data.eyebrow}</p>
        <h1 class="mt-6 max-w-4xl font-display text-[clamp(2.5rem,7vw,5.5rem)] leading-[0.98] tracking-[-0.01em] text-paper">
          {data.headline.lead}<br />
          <em class="text-phoenix-bright">{data.headline.emphasis}</em>
        </h1>
        <p class="mt-8 max-w-xl text-lg leading-relaxed text-fog">{data.sub}</p>
        <a
          href="#apply"
          class="mt-10 inline-block bg-paper px-7 py-3.5 font-sans text-base font-semibold text-ink transition-colors hover:bg-phoenix-bright"
        >
          {data.cta}
        </a>
      </div>
    </section>

    <section class="border-t border-line">
      <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
        <div class="reveal border-t border-line pt-3">
          <p class="font-mono text-[0.8125rem] tracking-[0.08em]">
            <span class="font-medium text-phoenix-bright">01</span>
            <span class="ml-3 lowercase text-fog-dim">{data.why.eyebrow.replace(/^\/\s*/, '')}</span>
          </p>
        </div>
        <div class="mt-10 grid gap-px bg-line md:grid-cols-3">
          {
            data.why.items.map((item) => (
              <div class="reveal bg-ink px-7 py-8">
                <h2 class="font-display text-2xl leading-tight text-paper md:text-3xl">{item.title}</h2>
                <p class="mt-3 text-[0.9375rem] leading-relaxed text-fog">{item.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-paper text-ink">
      <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
        <p class="reveal font-mono text-[0.8125rem] tracking-[0.08em]">
          <span class="font-medium text-phoenix">02</span>
          <span class="ml-3 lowercase text-soot">{data.work.eyebrow.replace(/^\/\s*/, '')}</span>
        </p>
        <ol class="mt-12 border-t border-paper-line">
          {
            data.work.items.map((item, i) => (
              <li class="reveal grid gap-2 border-b border-paper-line py-6 md:grid-cols-[6rem_18rem_1fr] md:gap-8">
                <span class="font-mono text-[0.8125rem] font-medium tracking-[0.08em] text-phoenix">0{i + 1}</span>
                <h2 class="font-display text-2xl leading-tight">{item.title}</h2>
                <p class="max-w-prose text-[0.9375rem] leading-relaxed text-soot">{item.body}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section class="grid-texture border-t border-line bg-ink-raised">
      <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
        <dl class="grid grid-cols-2 gap-x-6 gap-y-10 md:grid-cols-4">
          {
            data.proof.map((stat) => (
              <div class="reveal">
                <dd class="font-display text-5xl text-paper tabular-nums" data-countup={stat.value} data-suffix={stat.suffix}>
                  {stat.value.toLocaleString('en-US')}{stat.suffix}
                </dd>
                <dt class="mt-2 max-w-40 font-mono text-[0.75rem] leading-snug text-fog-dim">{stat.label}</dt>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <section class="border-t border-line">
      <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
        <div class="reveal border-t border-line pt-3">
          <p class="font-mono text-[0.8125rem] tracking-[0.08em]">
            <span class="font-medium text-phoenix-bright">03</span>
            <span class="ml-3 lowercase text-fog-dim">{data.bar.eyebrow.replace(/^\/\s*/, '')}</span>
          </p>
        </div>
        <ul class="mt-8 max-w-2xl space-y-4">
          {
            data.bar.items.map((item) => (
              <li class="reveal flex gap-3 text-[0.9375rem] leading-relaxed text-fog">
                <span class="font-mono text-phoenix-bright">+</span>
                {item}
              </li>
            ))
          }
        </ul>

        <div class="mt-16 border-t border-line">
          {
            data.faq.map((item) => (
              <details class="reveal group border-b border-line">
                <summary class="flex cursor-pointer list-none items-baseline justify-between gap-6 py-5 [&::-webkit-details-marker]:hidden">
                  <span class="font-display text-xl text-paper transition-colors group-hover:text-phoenix-bright md:text-2xl">{item.q}</span>
                  <span class="shrink-0 font-mono text-xl text-phoenix-bright transition-transform duration-200 group-open:rotate-45" aria-hidden="true">
                    +
                  </span>
                </summary>
                <p class="max-w-2xl pb-6 text-base leading-relaxed text-fog">{item.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <section id="apply" class="grid-texture relative overflow-hidden border-t border-line bg-ink-raised">
      <div class="relative mx-auto max-w-6xl px-6 py-20 md:py-28">
        <div class="reveal text-center">
          <p class="font-mono text-[0.8125rem] tracking-[0.08em]">
            <span class="font-medium text-phoenix-bright">04</span>
            <span class="ml-3 lowercase text-fog-dim">apply</span>
          </p>
          <h2 class="mt-5 font-display text-[clamp(2.5rem,6vw,4.5rem)] leading-[0.98] text-paper">
            {data.apply.headline.lead} <em class="text-phoenix-bright">{data.apply.headline.emphasis}</em>
          </h2>
          <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-fog">{data.apply.sub}</p>
        </div>
        <div class="reveal mx-auto mt-12 max-w-3xl">
          {
            formUrl ? (
              <iframe src={formUrl} title={formTitle} loading="lazy" class="h-[36rem] w-full border border-line bg-ink" />
            ) : (
              <div class="border border-line bg-ink px-6 py-8 font-mono text-[0.9375rem] leading-relaxed md:px-10">
                <p>
                  <span class="font-medium text-phoenix-bright">/// applications</span>
                  <span class="text-paper"> open with Cohort 3. Until then:</span>
                </p>
                <p class="mt-4">
                  <span class="text-fog-dim">$ </span>
                  <a href="https://hack-nation.ai" class="text-phoenix-bright underline underline-offset-4 hover:text-paper">
                    hack-nation.ai
                  </a>
                </p>
              </div>
            )
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</div>
<script src="../scripts/enhance.js"></script>
