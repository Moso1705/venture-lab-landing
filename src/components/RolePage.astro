---
/**
 * Shared template for /mba and /mentor. Same Unicorn Foundry system as the
 * main funnel: Inter + Instrument Serif, HN-Blue accents, whisper bands, pill CTAs.
 */
import Footer from './Footer.astro';
import GetInLine from './GetInLine.astro';
import { theRoom } from '../content/roles';

interface RoleData {
  eyebrow: string;
  badge: string;
  headline: { lead: string; emphasis: string };
  sub: string;
  meta: string[];
  cta: string;
  why: { marker: string; items: { title: string; body: string }[] };
  work: { marker: string; items: { title: string; body: string }[] };
  bar: { marker: string; items: string[] };
  proof: { value: number; suffix: string; label: string }[];
  faq: { q: string; a: string }[];
  apply: { marker: string; headline: string; sub: string };
}

interface Props {
  data: RoleData;
  formUrl: string;
  formTitle: string;
  role: 'mba' | 'mentor';
}

const { data, formUrl, formTitle, role } = Astro.props;
---

<header class="role-nav sticky top-0 z-50 border-b border-line bg-paper/92 backdrop-blur-md">
  <div class="role-nav__inner mx-auto flex max-w-6xl items-center justify-between px-6 py-4 md:px-8">
    <div class="role-nav__brand flex min-w-0 items-center">
      <a href="https://hack-nation.ai" rel="noopener" class="text-sm font-medium tracking-tight text-ink/70 transition-colors hover:text-ink">
        HN
      </a>
      <span class="role-nav__dot" aria-hidden="true">·</span>
      <a href="/" class="role-nav__wordmark flex min-w-0 items-baseline">
        <span class="text-sm font-semibold tracking-tight text-ink">VL</span>
        <span class="role-nav__wordmark-long hidden text-sm text-gray sm:inline">Venture Lab</span>
      </a>
    </div>
    <nav class="role-nav__links flex items-center" aria-label="Page">
      <a href="/" class="hidden text-sm text-ink/65 transition-colors hover:text-ink md:inline">
        The program
      </a>
      <a href="#apply" class="btn-ink role-nav__cta text-sm">Apply</a>
    </nav>
  </div>
</header>

<style>
  .role-nav a:not(.btn-ink) {
    text-decoration: none;
  }

  .role-nav__inner {
    gap: 1.25rem;
  }

  .role-nav__brand {
    gap: 0.75rem;
  }

  .role-nav__dot {
    display: inline-flex;
    color: var(--color-faint);
    font-size: 0.875rem;
    line-height: 1;
    user-select: none;
  }

  .role-nav__wordmark {
    gap: 0.4rem;
  }

  .role-nav__links {
    gap: 1.25rem;
  }

  .role-nav__cta.btn-ink {
    color: var(--color-paper);
    padding: 0.65rem 1.25rem;
  }
</style>

<main>
  <section class="hn-atmosphere overflow-hidden border-b border-line">
    <div class="relative mx-auto max-w-6xl px-6 pt-20 pb-16 md:px-8 md:pt-28 md:pb-20">
      <div class="reveal mx-auto max-w-3xl text-center">
        <p class="marker">{data.eyebrow}</p>
        <span class="mt-4 inline-flex items-center rounded-full border border-ink/10 bg-paper/85 px-3 py-1 text-[0.6875rem] font-medium tracking-[0.14em] text-ink uppercase">
          {data.badge}
        </span>
        <h1 class="display mt-5 text-[clamp(2.25rem,6vw,4.25rem)]">
          <span class="text-gray">{data.headline.lead}</span>
          {' '}
          <em class="italic text-ink">{data.headline.emphasis}</em>
        </h1>
        <p class="section-sub mx-auto max-w-xl">{data.sub}</p>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
          {
            data.meta.map((item) => (
              <span class="inline-flex items-center rounded-full border border-line bg-paper/80 px-3 py-1 text-xs font-medium text-soot">
                {item}
              </span>
            ))
          }
        </div>
        <a href="#apply" class="btn-ink mt-10">{data.cta}</a>
      </div>
    </div>
  </section>

  <section class="border-b border-line bg-paper">
    <div class="mx-auto max-w-6xl px-6 py-16 md:px-8 md:py-20">
      <p class="marker reveal text-center">{data.why.marker}</p>
      <div class="mt-10 grid gap-8 md:grid-cols-3 md:gap-10">
        {
          data.why.items.map((item) => (
            <div class="reveal">
              <h2 class="font-serif text-[1.35rem] leading-snug tracking-tight">{item.title}</h2>
              <p class="mt-3 text-[0.9375rem] leading-relaxed text-gray">{item.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="band-raised border-b border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 md:px-8 md:py-20">
      <p class="marker reveal">{data.work.marker}</p>
      <ol class="mt-10 space-y-0">
        {
          data.work.items.map((item, i) => (
            <li class="reveal grid gap-2 border-t border-line py-6 md:grid-cols-[4rem_14rem_1fr] md:gap-8 md:items-baseline">
              <span class="text-sm font-medium tracking-[0.08em] text-hn-blue">0{i + 1}</span>
              <h2 class="text-lg font-medium leading-tight tracking-tight">{item.title}</h2>
              <p class="max-w-prose text-[0.9375rem] leading-relaxed text-gray">{item.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="border-b border-line bg-paper">
    <div class="mx-auto max-w-6xl px-6 py-14 md:px-8 md:py-16">
      <dl class="grid grid-cols-2 gap-x-6 gap-y-10 md:grid-cols-4">
        {
          data.proof.map((stat) => (
            <div class="reveal">
              <dd class="display text-4xl tabular-nums text-hn-blue md:text-5xl" data-countup={stat.value} data-suffix={stat.suffix}>
                {stat.value.toLocaleString('en-US')}
                {stat.suffix}
              </dd>
              <dt class="mt-2 max-w-40 text-[0.8125rem] leading-snug text-gray">{stat.label}</dt>
            </div>
          ))
        }
      </dl>
      <p class="reveal mt-10 border-t border-line pt-4 text-sm leading-relaxed text-gray">{theRoom}</p>
    </div>
  </section>

  <section class="band-raised border-b border-line">
    <div class="mx-auto max-w-6xl px-6 py-16 md:px-8 md:py-20">
      <div class="grid gap-12 lg:grid-cols-[1fr_1.1fr] lg:gap-16">
        <div>
          <p class="marker reveal">{data.bar.marker}</p>
          <ul class="mt-8 max-w-xl space-y-4">
            {
              data.bar.items.map((item) => (
                <li class="reveal flex gap-3 text-[0.9375rem] leading-relaxed text-gray">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-hn-blue" aria-hidden="true" />
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <p class="marker reveal">FAQ</p>
          <div class="mt-6 border-t border-line">
            {
              data.faq.map((item) => (
                <details class="reveal group border-b border-line">
                  <summary class="flex cursor-pointer list-none items-baseline justify-between gap-6 py-5 [&::-webkit-details-marker]:hidden">
                    <span class="text-[0.9375rem] font-medium tracking-tight text-ink transition-colors group-hover:text-hn-blue">
                      {item.q}
                    </span>
                    <span class="shrink-0 text-xl text-gray transition-transform duration-200 group-open:rotate-45" aria-hidden="true">
                      +
                    </span>
                  </summary>
                  <p class="max-w-2xl pb-6 text-base leading-relaxed text-gray">{item.a}</p>
                </details>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="apply" class="border-b border-line bg-paper">
    <div class="mx-auto max-w-3xl px-6 py-16 md:px-8 md:py-20">
      <div class="reveal text-center">
        <p class="marker">{data.apply.marker}</p>
        <h2 class="mt-3 text-[clamp(1.5rem,4vw,2.25rem)] font-medium tracking-[0.06em] text-ink uppercase">
          {data.apply.headline}
        </h2>
        <p class="section-sub mx-auto max-w-md">{data.apply.sub}</p>
      </div>
      <div class="reveal mt-8">
        {
          formUrl ? (
            <iframe
              src={formUrl}
              title={formTitle}
              loading="lazy"
              class="h-[36rem] w-full rounded-2xl border border-line bg-paper shadow-[var(--shadow-soft)]"
            />
          ) : (
            <GetInLine role={role} note={data.apply.sub} cta="Notify me" showNote={false} />
          )
        }
      </div>
    </div>
  </section>
</main>
<Footer />
<script src="../scripts/enhance.js"></script>
