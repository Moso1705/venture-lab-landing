---
/**
 * Light header in the Hack-Nation style: HN · VL · Hack-Nation · partner slot.
 */
import { nav } from '../content/site';
---

<header id="site-nav" class="fixed inset-x-0 top-0 z-50 border-b border-transparent transition-[background-color,border-color,backdrop-filter] duration-200">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4 md:px-8">
    <div class="flex min-w-0 items-center gap-3 md:gap-5">
      <a href={nav.hn.href} rel="noopener" class="text-sm font-medium tracking-tight text-ink/70 transition-colors hover:text-ink">
        {nav.hn.label}
      </a>
      <span class="hidden h-4 w-px bg-line sm:block" aria-hidden="true"></span>
      <a href="#top" class="flex min-w-0 items-baseline gap-2">
        <span class="text-sm font-semibold tracking-tight">{nav.wordmark.short}</span>
        <span class="hidden text-sm text-gray sm:inline">{nav.wordmark.long}</span>
      </a>
      <span class="hidden h-4 w-px bg-line md:block" aria-hidden="true"></span>
      <a href={nav.parent.href} rel="noopener" class="hidden text-sm text-ink/70 transition-colors hover:text-ink md:inline">
        {nav.parent.label}
      </a>
    </div>

    <div class="flex items-center gap-4 md:gap-6">
      {
        nav.partnerSlot ? (
          <a href={nav.partnerSlot.href} rel="noopener" class="hidden items-center md:flex" aria-label={nav.partnerSlot.name}>
            <img src={nav.partnerSlot.logo} alt={nav.partnerSlot.name} class="h-6 w-auto opacity-70" />
          </a>
        ) : (
          <span
            class="hidden h-7 w-[4.5rem] items-center justify-center rounded border border-dashed border-line md:flex"
            aria-hidden="true"
            title="Partner logo"
          />
        )
      }
      <nav class="hidden items-center gap-5 md:flex" aria-label="Page sections">
        {
          nav.links.map((link) => (
            <a href={link.href} class="text-sm text-ink/65 transition-colors hover:text-ink">
              {link.label}
            </a>
          ))
        }
      </nav>
      <a href={nav.cta.href} class="btn-ink !px-5 !py-2.5 text-sm">
        {nav.cta.label}
      </a>
    </div>
  </div>
</header>

<script>
  const navEl = document.getElementById('site-nav')!;
  const onScroll = () => {
    if (window.scrollY > 12) {
      navEl.classList.add('bg-paper/90', 'border-line', 'backdrop-blur-md');
    } else {
      navEl.classList.remove('bg-paper/90', 'border-line', 'backdrop-blur-md');
    }
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
