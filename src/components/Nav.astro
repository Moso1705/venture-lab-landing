---
import { announcement, nav } from '../content/site';
---

<a
  href={announcement.href}
  class="block bg-phoenix px-4 py-2 text-center font-mono text-[0.8125rem] tracking-[0.08em] text-ink transition-colors hover:bg-phoenix-bright"
>
  <span class="font-medium">/// {announcement.label}</span>
  <span class="mx-2">{announcement.text}</span>
  <span class="underline underline-offset-4">{announcement.cta}</span>
</a>

<header class="sticky top-0 z-50 border-b border-line bg-ink/90 backdrop-blur-sm">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3.5">
    <a href="#top" class="flex items-baseline gap-2">
      <span class="font-sans text-[0.9375rem] font-bold tracking-tight text-paper">HACKNATION</span>
      <span class="font-mono text-[0.8125rem] text-phoenix-bright">/ venture lab</span>
    </a>
    <nav class="flex items-center gap-7" aria-label="Page sections">
      {
        nav.links.map((link) => (
          <a
            href={link.href}
            class="hidden font-mono text-[0.8125rem] lowercase tracking-[0.08em] text-fog transition-colors hover:text-paper md:block"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={nav.cta.href}
        class="bg-paper px-5 py-2 font-sans text-sm font-semibold text-ink transition-colors hover:bg-phoenix-bright"
      >
        {nav.cta.label}
      </a>
    </nav>
  </div>
</header>
