---
/**
 * The dark opening scene: a constellation of the HackNation network with the
 * hub cities as labeled nodes, the wordmark in the middle, one CTA. The only
 * dark band on the page besides nothing else; the rest of the page is paper.
 */
import { hero } from '../content/site';

// Labeled nodes: the published hub cities. Positions are composition, not geography.
const hubs = [
  { x: 165, y: 545, label: 'San Francisco', anchor: 'start', dy: 24 },
  { x: 430, y: 200, label: 'Boston', anchor: 'middle', dy: -16 },
  { x: 745, y: 140, label: 'London', anchor: 'middle', dy: -16 },
  { x: 1060, y: 265, label: 'Munich', anchor: 'start', dy: -16 },
  { x: 960, y: 470, label: 'Zurich', anchor: 'start', dy: 24 },
];

// The rest of the network stays unlabeled.
const dots = [
  { x: 90, y: 130 }, { x: 280, y: 90 }, { x: 585, y: 70 }, { x: 920, y: 80 },
  { x: 1210, y: 115 }, { x: 1365, y: 250 }, { x: 1390, y: 500 }, { x: 1265, y: 655 },
  { x: 1120, y: 745 }, { x: 855, y: 715 }, { x: 615, y: 765 }, { x: 370, y: 690 },
  { x: 130, y: 665 }, { x: 55, y: 395 }, { x: 305, y: 385 }, { x: 1185, y: 395 },
];

const nodes = [...hubs, ...dots];

// Connect near neighbors, capped per node so the mesh stays airy.
const MAX_DIST = 420;
const MAX_EDGES = 3;
const edgeCount = new Map<number, number>();
const lines: { x1: number; y1: number; x2: number; y2: number }[] = [];
for (let i = 0; i < nodes.length; i++) {
  for (let j = i + 1; j < nodes.length; j++) {
    const dx = nodes[i].x - nodes[j].x;
    const dy = nodes[i].y - nodes[j].y;
    if (Math.hypot(dx, dy) > MAX_DIST) continue;
    if ((edgeCount.get(i) ?? 0) >= MAX_EDGES || (edgeCount.get(j) ?? 0) >= MAX_EDGES) continue;
    edgeCount.set(i, (edgeCount.get(i) ?? 0) + 1);
    edgeCount.set(j, (edgeCount.get(j) ?? 0) + 1);
    lines.push({ x1: nodes[i].x, y1: nodes[i].y, x2: nodes[j].x, y2: nodes[j].y });
  }
}
---

<section id="hero" class="relative flex min-h-svh flex-col overflow-hidden bg-ink text-paper">
  <span id="top" class="absolute top-0" aria-hidden="true"></span>
  <svg
    class="constellation absolute inset-0 h-full w-full"
    viewBox="0 0 1440 800"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    <g class="drift-a" stroke="var(--color-paper)" stroke-width="0.75" opacity="0.13">
      {lines.map((l) => <line x1={l.x1} y1={l.y1} x2={l.x2} y2={l.y2} />)}
    </g>
    <g class="drift-b">
      {dots.map((d) => <circle cx={d.x} cy={d.y} r="2" fill="var(--color-paper)" opacity="0.55" />)}
      {
        hubs.map((h) => (
          <>
            <circle cx={h.x} cy={h.y} r="3" fill="var(--color-paper)" opacity="0.9" />
            <text
              x={h.x}
              y={h.y + h.dy}
              text-anchor={h.anchor}
              fill="var(--color-fog-dim)"
              font-family="var(--font-mono)"
              font-size="11"
              letter-spacing="2.5"
            >
              {h.label.toUpperCase()}
            </text>
          </>
        ))
      }
    </g>
  </svg>

  <div class="relative z-10 flex flex-1 flex-col items-center justify-center px-6 pt-24 pb-28 text-center">
    <p class="hero-enter font-mono text-[0.75rem] uppercase tracking-[0.3em] text-fog-dim" style="--d: 0ms">
      {hero.poweredBy}
    </p>
    <h1
      class="hero-enter mt-6 font-sans text-[clamp(3.25rem,9vw,7.5rem)] font-extralight uppercase leading-none tracking-[0.03em]"
      style="--d: 90ms"
    >
      {hero.wordmark}
    </h1>
    <p class="hero-enter mt-8 font-mono text-[clamp(0.8125rem,1.2vw,0.9375rem)] uppercase tracking-[0.3em] text-paper" style="--d: 180ms">
      {hero.subline}
    </p>
    <p class="hero-enter mt-4 font-mono text-[0.75rem] uppercase tracking-[0.22em] text-fog-dim" style="--d: 260ms">
      {hero.meta}
    </p>
    <div class="hero-enter mt-12 flex flex-col items-center gap-5 sm:flex-row sm:gap-8" style="--d: 340ms">
      <a href={hero.primaryCta.href} class="btn-paper">{hero.primaryCta.label}</a>
      <a
        href={hero.secondaryCta.href}
        class="font-mono text-[0.8125rem] lowercase tracking-[0.08em] text-fog underline-offset-4 transition-colors hover:text-paper hover:underline"
      >
        {hero.secondaryCta.label}
      </a>
    </div>
    <p class="hero-enter mt-12 max-w-md font-mono text-[0.75rem] uppercase leading-relaxed tracking-[0.16em] text-fog md:max-w-none" style="--d: 420ms">
      <span class="live-dot mr-2 inline-block h-1.5 w-1.5 rounded-full bg-phoenix-bright align-middle" aria-hidden="true"></span>
      {hero.live}
    </p>
  </div>

  <div class="absolute inset-x-0 bottom-0 z-10 flex items-end justify-between px-6 pb-6 md:px-10">
    <span class="hidden font-mono text-[0.6875rem] uppercase tracking-[0.22em] text-fog-dim md:block">cohort 3</span>
    <a
      href="#program"
      class="hero-enter mx-auto flex h-11 w-11 items-center justify-center rounded-full border border-line-ink text-fog transition-colors hover:border-fog hover:text-paper"
      style="--d: 500ms"
      aria-label="Scroll to the program"
    >
      ↓
    </a>
    <span class="hidden font-mono text-[0.6875rem] uppercase tracking-[0.22em] text-fog-dim md:block">{hero.networkNote}</span>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .hero-enter {
      opacity: 0;
      transform: translateY(14px);
      animation: hero-enter-in 0.7s var(--ease-out-quart) var(--d, 0ms) forwards;
    }
    @keyframes hero-enter-in {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    .constellation {
      opacity: 0;
      animation: constellation-in 1.4s ease 0.15s forwards;
    }
    @keyframes constellation-in {
      to {
        opacity: 1;
      }
    }
    /* Barely-there drift keeps the network alive without demanding attention. */
    .drift-a {
      animation: drift 34s ease-in-out infinite alternate;
    }
    .drift-b {
      animation: drift 26s ease-in-out infinite alternate-reverse;
    }
    @keyframes drift {
      from {
        transform: translate(0, 0);
      }
      to {
        transform: translate(7px, -5px);
      }
    }
    .live-dot {
      animation: live-pulse 2.4s ease-in-out infinite;
    }
    @keyframes live-pulse {
      50% {
        opacity: 0.3;
      }
    }
  }
</style>
