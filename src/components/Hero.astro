---
import { hero } from '../content/site';
import Ruler from './Ruler.astro';
---

<section id="top" class="grid-texture relative overflow-hidden">
  <!-- depth layers -->
  <div class="glow-warm -top-40 -left-40 h-[34rem] w-[34rem]" aria-hidden="true"></div>
  <div class="light-ray -top-1/4 right-[12%] hidden h-[150%] w-40 md:block" aria-hidden="true"></div>
  <div class="grid-spotlight pointer-events-none absolute inset-0" aria-hidden="true"></div>
  <canvas
    id="glyph-field"
    class="pointer-events-none absolute top-0 right-0 bottom-14 hidden w-[42%] lg:block"
    aria-hidden="true"></canvas>

  <div class="relative mx-auto max-w-6xl px-6 pt-20 pb-16 md:pt-28 md:pb-20">
    <aside
      class="hero-enter absolute top-28 right-6 hidden border border-line bg-ink-raised/80 px-5 py-4 backdrop-blur-[2px] lg:block"
      style="animation-delay: 480ms"
      aria-label="Next cohort at a glance"
    >
      {
        hero.telemetry.map((line, i) => (
          <p
            class:list={[
              'font-mono text-[0.75rem] leading-loose tracking-[0.08em]',
              i === 0 ? 'text-phoenix-bright' : 'text-fog',
            ]}
          >
            {line}
          </p>
        ))
      }
    </aside>

    <p class="eyebrow hero-enter" data-scramble>{hero.eyebrow}</p>
    <h1
      class="mt-6 max-w-4xl font-display text-[clamp(2.75rem,8vw,6.5rem)] leading-[0.98] tracking-[-0.01em] text-paper"
    >
      <span class="hero-line"><span class="hero-line-inner">{hero.headline.lead}</span></span>
      <span class="hero-line"
        ><em class="hero-line-inner text-phoenix-bright" style="animation-delay: 140ms"
          >{hero.headline.emphasis}</em
        ></span
      >
    </h1>
    <p class="hero-enter mt-8 max-w-xl text-lg leading-relaxed text-fog" style="animation-delay: 280ms">
      {hero.sub}
    </p>
    <div class="hero-enter mt-10 flex flex-wrap items-center gap-4" style="animation-delay: 380ms">
      <a
        href={hero.primaryCta.href}
        class="bg-paper px-7 py-3.5 font-sans text-base font-semibold text-ink transition-colors duration-200 hover:bg-phoenix-bright"
      >
        {hero.primaryCta.label}
      </a>
      <a
        href={hero.secondaryCta.href}
        class="border border-line px-7 py-3.5 font-sans text-base font-medium text-fog transition-colors duration-200 hover:border-fog hover:text-paper"
      >
        {hero.secondaryCta.label}
      </a>
    </div>
  </div>

  <Ruler />

  <dl class="relative mx-auto grid max-w-6xl grid-cols-2 gap-px px-6 py-10 md:grid-cols-4">
    {
      hero.stats.map((stat) => (
        <div class="border-l border-line pl-4">
          <dd class="font-display text-4xl text-paper tabular-nums md:text-5xl" data-countup={stat.value} data-suffix={stat.suffix}>
            {stat.value.toLocaleString('en-US')}{stat.suffix}
          </dd>
          <dt class="mt-2 max-w-44 font-mono text-[0.75rem] leading-snug text-fog-dim">{stat.label}</dt>
        </div>
      ))
    }
  </dl>
</section>

<style>
  /* Orchestrated entrance: lines rise out of clip masks, everything else
     fades up in sequence. Total budget ~1.1s. Reduced motion: final state. */
  .hero-line {
    display: block;
    overflow: clip;
  }
  .hero-line-inner {
    display: block;
    animation: hero-line-up 0.75s var(--ease-out-quart) both;
  }
  .hero-enter {
    animation: hero-rise 0.7s var(--ease-out-quart) both;
  }
  @keyframes hero-line-up {
    from {
      transform: translateY(105%);
    }
    to {
      transform: translateY(0);
    }
  }
  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-enter,
    .hero-line-inner {
      animation: none;
    }
  }

  /* Pointer spotlight: the hero grid brightens around the cursor. */
  .grid-spotlight {
    opacity: 0;
    background-image:
      linear-gradient(to right, color-mix(in srgb, var(--color-phoenix-bright) 26%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in srgb, var(--color-phoenix-bright) 26%, transparent) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(320px circle at var(--mx, 50%) var(--my, 50%), black 0%, transparent 100%);
    -webkit-mask-image: radial-gradient(320px circle at var(--mx, 50%) var(--my, 50%), black 0%, transparent 100%);
    transition: opacity 0.4s ease;
  }
</style>

<script>
  // Spotlight follows the pointer; skipped for touch devices and reduced motion.
  const fine = window.matchMedia('(pointer: fine)').matches;
  const motionOk = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;
  const section = document.getElementById('top');
  const spot = section?.querySelector<HTMLElement>('.grid-spotlight');
  if (fine && motionOk && section && spot) {
    let raf = 0;
    section.addEventListener('pointermove', (e) => {
      if (raf) return;
      raf = requestAnimationFrame(() => {
        const rect = section.getBoundingClientRect();
        spot.style.setProperty('--mx', `${e.clientX - rect.left}px`);
        spot.style.setProperty('--my', `${e.clientY - rect.top}px`);
        spot.style.opacity = '1';
        raf = 0;
      });
    });
    section.addEventListener('pointerleave', () => {
      spot.style.opacity = '0';
    });
  }
</script>

<script>
  // Generative glyph field: a monospace character terrain drifting on the
  // hero's right half. Value-noise brightness picks the glyph; the cursor
  // warms nearby cells to phoenix orange. Desktop only, 24fps, pauses when
  // the hero leaves the viewport. Reduced motion gets a single static frame.
  const canvas = document.getElementById('glyph-field') as HTMLCanvasElement | null;
  const heroSection = document.getElementById('top');
  if (canvas && heroSection && window.matchMedia('(min-width: 64rem)').matches) {
    const ctx = canvas.getContext('2d');
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const RAMP = ' ..::--=+*#%@';
    const CELL = 16;
    const FPS = 24;
    let cols = 0;
    let rows = 0;
    let pointer = { x: -9999, y: -9999 };
    let running = false;
    let last = 0;

    const resize = () => {
      const rect = canvas.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 1.25);
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      ctx?.scale(dpr, dpr);
      cols = Math.ceil(rect.width / CELL);
      rows = Math.ceil(rect.height / CELL);
    };

    const noise = (x: number, y: number, t: number) =>
      0.5 +
      0.28 * Math.sin(x * 0.7 + t * 0.6) * Math.cos(y * 0.55 - t * 0.4) +
      0.22 * Math.sin((x + y) * 0.32 + t * 0.9);

    const draw = (t: number) => {
      if (!ctx) return;
      const rect = canvas.getBoundingClientRect();
      ctx.clearRect(0, 0, rect.width, rect.height);
      ctx.font = '12px "DM Mono", monospace';
      const time = t / 1000;
      for (let gy = 0; gy < rows; gy++) {
        for (let gx = 0; gx < cols; gx++) {
          const v = noise(gx, gy, time);
          const idx = Math.max(0, Math.min(RAMP.length - 1, Math.floor(v * RAMP.length)));
          const ch = RAMP[idx];
          if (ch === ' ') continue;
          const px = gx * CELL;
          const py = gy * CELL + 12;
          const dx = px - pointer.x;
          const dy = py - pointer.y;
          const near = Math.max(0, 1 - Math.hypot(dx, dy) / 180);
          // fade the field toward the text side so it never fights the headline
          const edgeFade = Math.min(1, gx / (cols * 0.35));
          const alpha = (0.05 + v * 0.1 + near * 0.5) * edgeFade;
          ctx.fillStyle = near > 0.08 ? `rgba(255, 92, 38, ${alpha})` : `rgba(180, 174, 165, ${alpha})`;
          ctx.fillText(ch, px, py);
        }
      }
    };

    const loop = (now: number) => {
      if (!running) return;
      if (now - last >= 1000 / FPS) {
        last = now;
        draw(now);
      }
      requestAnimationFrame(loop);
    };

    resize();
    window.addEventListener('resize', resize);
    heroSection.addEventListener('pointermove', (e) => {
      const rect = canvas.getBoundingClientRect();
      pointer = { x: e.clientX - rect.left, y: e.clientY - rect.top };
    });
    heroSection.addEventListener('pointerleave', () => {
      pointer = { x: -9999, y: -9999 };
    });

    if (reduced) {
      draw(0);
    } else {
      new IntersectionObserver((entries) => {
        const visible = entries[0].isIntersecting;
        if (visible && !running) {
          running = true;
          requestAnimationFrame(loop);
        } else if (!visible) {
          running = false;
        }
      }).observe(heroSection);
    }
  }
</script>
