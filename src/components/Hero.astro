---
import { hero } from '../content/site';
import Ruler from './Ruler.astro';
---

<section id="top" class="grid-texture relative overflow-hidden">
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-6xl px-6 pt-24 pb-16 md:pt-32 md:pb-20">
    <aside
      class="hero-enter absolute top-32 right-6 hidden border border-line bg-ink-raised px-5 py-4 lg:block"
      style="animation-delay: 520ms"
      aria-label="Next cohort at a glance"
    >
      {
        hero.telemetry.map((line, i) => (
          <p
            class:list={[
              'font-mono text-[0.75rem] leading-loose tracking-[0.08em]',
              i === 0 ? 'text-phoenix-bright' : 'text-fog',
            ]}
          >
            {line}
          </p>
        ))
      }
    </aside>

    <p class="eyebrow hero-enter">{hero.eyebrow}</p>
    <h1
      class="mt-8 font-display text-[clamp(3rem,8.5vw,6.5rem)] leading-[0.95] tracking-[-0.02em] text-paper"
    >
      <span class="hero-line"><span class="hero-line-inner">{hero.headline.lead}</span></span>
      <span class="hero-line"
        ><em class="hero-line-inner text-phoenix-bright" style="animation-delay: 140ms"
          >{hero.headline.emphasis}</em
        ></span
      >
    </h1>
    <div class="hero-enter relative mt-4 hidden max-w-5xl md:block" style="animation-delay: 420ms" aria-hidden="true">
      <p class="absolute right-0 font-mono text-[0.6875rem] tracking-[0.08em] text-fog-dim">
        <span class="text-phoenix-bright">fig. 01</span> — the jump from prototype to company
      </p>
    </div>
    <p class="hero-enter mt-10 max-w-xl text-lg leading-relaxed text-fog" style="animation-delay: 280ms">
      {hero.sub}
    </p>
    <div class="hero-enter mt-10 flex flex-wrap items-center gap-6" style="animation-delay: 380ms">
      <a
        href={hero.primaryCta.href}
        class="bg-paper px-8 py-4 font-sans text-base font-semibold text-ink transition-colors duration-200 hover:bg-phoenix-bright"
      >
        {hero.primaryCta.label}
      </a>
      <a
        href={hero.secondaryCta.href}
        class="group font-mono text-[0.8125rem] tracking-[0.08em] text-fog transition-colors duration-200 hover:text-paper"
      >
        {hero.secondaryCta.label}
        <span class="ml-1 inline-block transition-transform duration-200 group-hover:translate-y-0.5">↓</span>
      </a>
    </div>
  </div>

  <Ruler />

  <dl class="relative mx-auto grid max-w-6xl grid-cols-2 gap-px px-6 py-10 md:grid-cols-4">
    {
      hero.stats.map((stat) => (
        <div class="border-l border-line pl-4">
          <dd class="font-display text-4xl text-paper tabular-nums md:text-5xl" data-countup={stat.value} data-suffix={stat.suffix}>
            {stat.value.toLocaleString('en-US')}{stat.suffix}
          </dd>
          <dt class="mt-2 max-w-44 font-mono text-[0.75rem] leading-snug text-fog-dim">{stat.label}</dt>
        </div>
      ))
    }
  </dl>
</section>

<style>
  /* One dim warm light source. The only glow on the page. */
  .hero-glow {
    position: absolute;
    top: -12rem;
    left: -10rem;
    width: 30rem;
    height: 30rem;
    border-radius: 9999px;
    pointer-events: none;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--color-phoenix) 22%, transparent) 0%,
      color-mix(in srgb, var(--color-phoenix) 7%, transparent) 45%,
      transparent 70%
    );
    filter: blur(70px);
  }

  /* Orchestrated entrance: lines rise out of clip masks, everything else
     fades up in sequence. Total budget ~1.1s. Reduced motion: final state. */
  .hero-line {
    display: block;
    overflow: clip;
  }
  .hero-line-inner {
    display: block;
    animation: hero-line-up 0.75s var(--ease-out-quart) both;
  }
  .hero-enter {
    animation: hero-rise 0.7s var(--ease-out-quart) both;
  }
  @keyframes hero-line-up {
    from {
      transform: translateY(105%);
    }
    to {
      transform: translateY(0);
    }
  }
  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-enter,
    .hero-line-inner {
      animation: none;
    }
  }
</style>
