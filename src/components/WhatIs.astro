---
/**
 * Funnel top: hero, what we give you, how to apply.
 * No week grid, no Clear the gate (voice: keep it a funnel, not a structured program).
 */
import { whatIs } from '../content/site';
---

<section id="program" class="hn-atmosphere overflow-hidden pt-28 md:pt-32">
  <span id="top" class="absolute top-0" aria-hidden="true"></span>
  <div class="relative mx-auto max-w-6xl px-6 pb-2 md:px-8">
    <div class="reveal mx-auto max-w-3xl text-center">
      <p class="marker">{whatIs.eyebrow}</p>
      <span class="mt-4 inline-flex items-center rounded-full border border-ink/10 bg-paper/85 px-3 py-1 text-[0.6875rem] font-medium tracking-[0.14em] text-ink uppercase">
        {whatIs.badge}
      </span>
      <h1 class="display mt-5 text-[clamp(2.5rem,7vw,5rem)]">
        <span class="text-gray">{whatIs.headline.lead}</span>
        {' '}
        <em class="italic text-ink">{whatIs.headline.emphasis}</em>
      </h1>
      {
        whatIs.sub && (
          <p class="section-sub mx-auto max-w-xl">{whatIs.sub}</p>
        )
      }
    </div>
  </div>

  <!-- This is what we give you -->
  <div class="relative mx-auto max-w-6xl px-6 py-16 md:px-8 md:py-20">
    <div class="reveal mx-auto max-w-5xl">
      <p class="pillars-label text-center">{whatIs.pillarsLabel}</p>
      <div class="pillars mt-10">
        {
          whatIs.pillars.map((pillar) => (
            <div class="pillar">
              <h2 class="text-[0.9375rem] font-medium tracking-tight text-ink">{pillar.title}</h2>
              <p class="mt-2 text-sm leading-relaxed text-gray">{pillar.body}</p>
            </div>
          ))
        }
      </div>

      <div class="mt-12 border-t border-line pt-8">
        <p class="marker text-center">{whatIs.partners.line}</p>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-x-12 gap-y-5">
          {
            whatIs.partners.orgs.map((org) => (
              <a
                href={org.href}
                rel="noopener"
                target="_blank"
                class="opacity-70 transition-opacity hover:opacity-100"
                aria-label={org.name}
              >
                <img src={org.logo} alt={org.name} height={org.h} style={`height:${org.h}px`} class="w-auto" loading="lazy" />
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <!-- HOW TO APPLY: intentional large HN-Blue -->
  <div class="border-t border-line bg-paper">
    <div class="reveal mx-auto max-w-6xl px-6 py-16 md:px-8 md:py-20">
      <div class="mx-auto max-w-5xl">
        <div class="flex flex-wrap items-end justify-between gap-3">
          <h2 class="font-serif text-[clamp(1.75rem,4.5vw,2.75rem)] leading-none tracking-tight text-hn-blue uppercase">
            {whatIs.pathLabel}
          </h2>
          <p class="marker-blue">{whatIs.pathEnd}</p>
        </div>

        <ol class="path-rail mt-10 md:mt-12">
          {
            whatIs.steps.map((step) => (
              <li class="path-rail__step">
                <p class="path-rail__num" aria-hidden="true">{step.num}</p>
                <h3 class="mt-3 text-lg font-medium tracking-tight text-ink">{step.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-gray">{step.body}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </div>
</section>

<style>
  .pillars-label {
    font-family: var(--font-sans);
    font-size: clamp(0.8125rem, 1.4vw, 0.9375rem);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .pillars {
    display: grid;
    gap: 1.75rem;
    list-style: none;
  }

  @media (min-width: 640px) {
    .pillars {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.75rem 2.25rem;
    }
  }

  @media (min-width: 1024px) {
    .pillars {
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 0;
    }

    .pillar {
      padding-inline: 0.85rem;
      border-left: 1px solid var(--color-line);
    }

    .pillar:first-child {
      padding-left: 0;
      border-left: none;
    }

    .pillar:last-child {
      padding-right: 0;
    }
  }

  .path-rail {
    display: grid;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .path-rail__num {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    line-height: 1;
    letter-spacing: 0.02em;
    color: var(--color-hn-blue);
  }

  @media (min-width: 768px) {
    .path-rail {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0;
      align-items: start;
    }

    .path-rail__step {
      padding-inline: 0.75rem;
      padding-right: 1.25rem;
    }

    .path-rail__step:first-child {
      padding-left: 0;
    }

    .path-rail__step:last-child {
      padding-right: 0;
    }
  }
</style>
