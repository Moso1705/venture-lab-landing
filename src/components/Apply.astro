---
import { apply, applyFormUrl } from '../content/site';
import GetInLine from './GetInLine.astro';
---

<section id="apply" class="grid-texture relative overflow-hidden border-t border-line bg-ink-raised">
  <div class="relative mx-auto max-w-6xl px-6 py-28 md:py-40">
    <div class="reveal text-center">
      <p class="font-mono text-[0.8125rem] tracking-[0.08em]">
        <span class="font-medium text-phoenix-bright">11</span>
        <span class="ml-3 lowercase text-fog-dim">{apply.eyebrow.replace(/^\/\s*/, '')}</span>
      </p>
      <h2 class="mt-5 font-display text-[clamp(2.75rem,7vw,5.5rem)] leading-[0.98] text-paper">
        {apply.headline.lead} <em class="text-phoenix-bright">{apply.headline.emphasis}</em>
      </h2>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-fog">{apply.sub}</p>
    </div>

    <div class="reveal mx-auto mt-14 max-w-3xl">
      {
        applyFormUrl ? (
          <iframe
            src={applyFormUrl}
            title="Cohort 3 application form"
            loading="lazy"
            class="h-[40rem] w-full border border-line bg-ink"
          />
        ) : (
          <GetInLine
            role="founder"
            prompt="/// get_in_line — cohort 3."
            note="Applications open after Investor Day, July 31. Leave your email and you hear from us before anyone else."
          />
        )
      }
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .cursor-blink {
      animation: blink 1.1s steps(1) infinite;
    }
    @keyframes blink {
      50% {
        opacity: 0;
      }
    }
  }
</style>
