---
/**
 * The close: request a spot. While the real form does not exist, the
 * get-in-line capture stands in. Three short routes below cover every
 * visitor: hackathon alum, outside builder, not built yet.
 */
import { apply, applyFormUrl } from '../content/site';
import GetInLine from './GetInLine.astro';
---

<section id="apply" class="border-t border-line">
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
    <p class="marker reveal">{apply.marker}</p>
    <h2 class="display reveal mt-6 text-[clamp(2.5rem,5.5vw,4.25rem)]">{apply.headline}</h2>
    <p class="reveal mt-5 max-w-2xl text-[1.0625rem] leading-relaxed text-gray">{apply.sub}</p>

    <div class="reveal mt-12 max-w-3xl">
      {
        applyFormUrl ? (
          <iframe
            src={applyFormUrl}
            title="Cohort 3 application form"
            loading="lazy"
            class="h-[40rem] w-full border border-line bg-paper"
          />
        ) : (
          <GetInLine
            role="founder"
            note="Applications open after Investor Day, July 31. Leave your email and you hear from us before anyone else."
          />
        )
      }
    </div>

    <div class="mt-16 grid gap-x-10 gap-y-10 md:grid-cols-3">
      {
        apply.routes.map((route) => (
          <div class="reveal border-t border-line pt-5">
            <h3 class="text-lg font-medium">{route.title}</h3>
            <p class="mt-2 text-[0.9375rem] leading-relaxed text-gray">{route.body}</p>
            {route.link && (
              <a
                href={route.link.href}
                rel="noopener"
                target="_blank"
                class="mt-3 inline-block font-mono text-[0.8125rem] tracking-[0.08em] text-ink underline underline-offset-4 transition-colors hover:text-phoenix"
              >
                {route.link.label} ↗
              </a>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
