---
/**
 * Founder notify / apply band. White canvas after the gray paths band.
 */
import { apply, applyFormUrl } from '../content/site';
import GetInLine from './GetInLine.astro';
---

<section id="apply" class="bg-paper">
  <div class="mx-auto max-w-3xl px-6 py-16 md:px-8 md:py-20">
    <div class="reveal text-center">
      <p class="marker">{apply.marker}</p>
      <h2 class="mt-4 text-[clamp(1.5rem,4vw,2.25rem)] font-medium tracking-[0.04em] text-ink uppercase">
        {apply.headline}
      </h2>
      <p class="mx-auto mt-4 max-w-md text-base leading-relaxed text-gray">{apply.sub}</p>
    </div>
    <div class="reveal mt-8">
      {
        applyFormUrl ? (
          <iframe
            src={applyFormUrl}
            title="Venture Lab application form"
            loading="lazy"
            class="h-[36rem] w-full rounded-2xl border border-line bg-paper shadow-[var(--shadow-soft)]"
          />
        ) : (
          <GetInLine role="founder" note={apply.sub} cta={apply.cta} finePrint={apply.note} />
        )
      }
    </div>
  </div>
</section>
