---
import { startups } from '../content/site';
import SectionHead from './SectionHead.astro';
---

<section id="startups">
  <div class="mx-auto max-w-6xl px-6 pt-20 pb-24 md:pt-24 md:pb-32">
    <SectionHead index="05" label={startups.eyebrow.replace(/^\/\s*/, '')} annotation={startups.intro.toLowerCase()}>
      <h2 class="mt-10 max-w-2xl font-display text-3xl leading-tight text-paper md:text-4xl">
        {startups.headline.lead} {startups.headline.emphasis}
      </h2>
    </SectionHead>

    <!-- The portfolio as a ruled index, not cards: name / focus / what it is / traction. -->
    <ol class="mt-12 border-t border-line">
      {
        startups.companies.map((company) => {
          const Tag = company.url ? 'a' : 'div';
          return (
            <li class="border-b border-line">
              <Tag
                class:list={[
                  'group grid gap-x-6 gap-y-1 py-5 md:grid-cols-[13rem_7rem_1fr_15rem] md:items-baseline',
                  company.url && 'transition-colors duration-150 hover:bg-ink-raised',
                ]}
                href={company.url}
                target={company.url ? '_blank' : undefined}
                rel={company.url ? 'noopener' : undefined}
              >
                <h3 class="font-display text-2xl text-paper">
                  {company.name}
                  {company.url && (
                    <span class="ml-1 inline-block font-mono text-sm text-phoenix-bright transition-transform duration-150 group-hover:-translate-y-0.5 group-hover:translate-x-0.5">
                      ↗
                    </span>
                  )}
                </h3>
                <span class="font-mono text-[0.6875rem] tracking-[0.08em] text-fog-dim lowercase">{company.tag}</span>
                <p class="text-[0.9375rem] leading-relaxed text-fog">{company.line}</p>
                <p class="font-mono text-[0.75rem] tracking-[0.04em] text-phoenix-bright md:text-right">
                  {company.traction}
                </p>
              </Tag>
            </li>
          );
        })
      }
    </ol>
  </div>
</section>
