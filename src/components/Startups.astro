---
import { startups } from '../content/site';
import SectionHead from './SectionHead.astro';

const half = Math.ceil(startups.companies.length / 2);
const rowA = startups.companies.slice(0, half);
const rowB = startups.companies.slice(half);
---

<section id="startups">
  <div class="mx-auto max-w-6xl px-6 pt-20 md:pt-24">
    <SectionHead index="05" label={startups.eyebrow.replace(/^\/\s*/, '')} annotation={startups.intro.toLowerCase()}>
      <h2 class="mt-10 max-w-2xl font-display text-3xl leading-tight text-paper md:text-4xl">
        {startups.headline.lead} {startups.headline.emphasis}
      </h2>
    </SectionHead>
  </div>

  <div class="mt-14 space-y-4 overflow-hidden pb-24 md:pb-32">
    {
      [rowA, rowB].map((row, i) => (
        <div class="marquee-row" data-reverse={i === 1 ? 'true' : undefined}>
          <div class="marquee-track gap-4 pr-4">
            {[false, true].map((isClone) =>
              row.map((company) => {
                const Tag = company.url ? 'a' : 'article';
                const monogram = company.name.replace(/[^A-Za-z0-9]/g, '').slice(0, 2).toUpperCase();
                return (
                  <Tag
                    class="group w-72 shrink-0 border border-line bg-ink-raised px-6 py-5 transition-[border-color,transform] duration-200 hover:-translate-y-0.5 hover:border-phoenix"
                    aria-hidden={isClone || undefined}
                    href={company.url}
                    target={company.url ? '_blank' : undefined}
                    rel={company.url ? 'noopener' : undefined}
                    tabindex={isClone ? -1 : undefined}
                  >
                    <div class="flex items-center gap-3">
                      <span class="flex size-8 shrink-0 items-center justify-center border border-phoenix/50 font-mono text-[0.6875rem] font-medium text-phoenix-bright">
                        {monogram}
                      </span>
                      <h3 class="font-display text-2xl text-paper">{company.name}</h3>
                      <span class="ml-auto font-mono text-[0.6875rem] tracking-[0.08em] text-fog-dim group-hover:text-phoenix-bright">
                        {company.tag}
                      </span>
                    </div>
                    <p class="mt-3 text-sm leading-relaxed text-fog">{company.line}</p>
                  </Tag>
                );
              })
            )}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .marquee-row[data-reverse] .marquee-track {
    animation-direction: reverse;
  }
  /* Reduced motion: the duplicated half is decorative, hide it and wrap the rest */
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      flex-wrap: wrap;
      width: auto;
      max-width: 72rem;
      margin-inline: auto;
      padding-inline: 1.5rem;
    }
    .marquee-track > :nth-child(n + 7) {
      display: none;
    }
  }
</style>
