---
/**
 * The startup index: one hairline row per company, traction on the right.
 * Reads like a ledger, not a card wall.
 */
import { startups } from '../content/site';
---

<section id="startups" class="border-t border-line">
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div>
        <p class="marker reveal">{startups.marker}</p>
        <h2 class="display reveal mt-6 text-[clamp(2.25rem,4.5vw,3.5rem)]">{startups.headline}</h2>
      </div>
      <p class="reveal max-w-xs pb-2 text-[0.9375rem] leading-relaxed text-gray">{startups.intro}</p>
    </div>

    <div class="mt-14 border-t border-line">
      {
        startups.companies.map((company) => {
          const Row = company.url ? 'a' : 'div';
          const rowProps = company.url ? { href: company.url, rel: 'noopener', target: '_blank' } : {};
          return (
            <Row
              {...rowProps}
              class:list={[
                'reveal group grid gap-x-8 gap-y-1.5 border-b border-line py-6 md:grid-cols-[15rem_minmax(0,1fr)_14rem] md:items-baseline',
                company.url && 'cursor-pointer',
              ]}
            >
              <p class="text-xl font-medium transition-colors group-hover:text-phoenix">
                {company.name}
                {company.url && <span class="ml-1 inline-block text-sm text-gray" aria-hidden="true">↗</span>}
              </p>
              <p class="text-[1.0625rem] leading-relaxed text-gray">
                {company.line}
                <span class="ml-3 font-mono text-[0.75rem] uppercase tracking-[0.16em] text-faint">{company.tag}</span>
              </p>
              <p class="font-mono text-[0.8125rem] tracking-[0.04em] text-soot md:text-right">{company.traction}</p>
            </Row>
          );
        })
      }
    </div>
  </div>
</section>
