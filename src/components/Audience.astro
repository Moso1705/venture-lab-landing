---
import { audience } from '../content/site';
import SectionHead from './SectionHead.astro';
---

<section>
  <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
    <SectionHead index="07" label={audience.eyebrow.replace(/^\/\s*/, '')} annotation={audience.soloNote.toLowerCase()}>
      <h2 class="mt-10 max-w-2xl font-display text-3xl leading-tight text-paper md:text-4xl">
        {audience.headline.lead} {audience.headline.emphasis}
      </h2>
    </SectionHead>

    <div class="mt-16 grid gap-10 md:grid-cols-2 md:gap-6">
      <div class="reveal border-t-2 border-paper pt-6">
        <h3 class="font-display text-3xl text-paper">{audience.forYou.title}</h3>
        <ul class="mt-6 space-y-4">
          {
            audience.forYou.items.map((item) => (
              <li class="flex gap-3 text-[0.9375rem] leading-relaxed text-fog">
                <span class="font-mono text-phoenix-bright">+</span>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="reveal border-t-2 border-fog-dim pt-6">
        <h3 class="font-display text-3xl text-fog">{audience.notForYou.title}</h3>
        <ul class="mt-6 space-y-4">
          {
            audience.notForYou.items.map((item) => (
              <li class="flex gap-3 text-[0.9375rem] leading-relaxed text-fog-dim">
                <span class="font-mono">–</span>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
