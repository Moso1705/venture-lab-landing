---
/**
 * Two honest columns, HN12-style: who this is for, who it is not for.
 * The "not for" column deliberately sits quieter.
 */
import { audience } from '../content/site';
---

<section class="border-t border-line">
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
    <p class="marker reveal">{audience.marker}</p>
    <div class="mt-10 grid gap-16 md:grid-cols-2 md:gap-12">
      <div class="reveal">
        <h2 class="display border-b border-line pb-5 text-[clamp(1.75rem,3vw,2.375rem)]">{audience.forYou.title}</h2>
        <ul class="mt-9 space-y-7">
          {
            audience.forYou.items.map((item) => (
              <li class="flex gap-5">
                <span class="mt-3 h-1 w-1 shrink-0 rounded-full bg-ink" aria-hidden="true" />
                <p class="text-[1.0625rem] leading-relaxed text-gray">
                  <strong class="font-medium text-ink">{item.lead}</strong> {item.body}
                </p>
              </li>
            ))
          }
        </ul>
        <p class="mt-9 text-[0.9375rem] text-gray">{audience.soloNote}</p>
      </div>
      <div class="reveal text-faint md:border-l md:border-line md:pl-12">
        <h2 class="display border-b border-line pb-5 text-[clamp(1.75rem,3vw,2.375rem)]">{audience.notForYou.title}</h2>
        <ul class="mt-9 space-y-7">
          {
            audience.notForYou.items.map((item) => (
              <li class="flex gap-5">
                <span class="mt-3 h-1 w-1 shrink-0 rounded-full bg-faint" aria-hidden="true" />
                <p class="text-[1.0625rem] leading-relaxed">
                  <strong class="font-medium text-soot">{item.lead}</strong> {item.body}
                </p>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
