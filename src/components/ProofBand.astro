---
import { proof } from '../content/site';
---

<section id="proof" class="grid-texture border-t border-line bg-ink-raised">
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    <p class="eyebrow reveal">{proof.eyebrow}</p>
    <dl class="mt-10 grid grid-cols-2 gap-x-6 gap-y-10 md:grid-cols-5">
      {
        proof.stats.map((stat) => (
          <div class="reveal">
            <dd class="font-display text-5xl text-paper md:text-6xl">{stat.value}</dd>
            <dt class="mt-3 max-w-40 font-mono text-[0.75rem] leading-snug text-fog-dim">{stat.label}</dt>
          </div>
        ))
      }
    </dl>
  </div>
</section>
