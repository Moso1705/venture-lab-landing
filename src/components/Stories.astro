---
/**
 * Outcomes: HN-style testimonial carousel + company examples.
 * Partner logos live under What you get; this section stays proof-focused.
 */
import { stories } from '../content/site';
const slides = stories.testimonials;
---
<section id="stories" class="band-raised border-t border-line">
  <div class="mx-auto max-w-6xl px-6 py-20 md:px-8 md:py-28">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="marker">{stories.marker}</p>
      <h2 class="section-title mt-4 italic">{stories.headline}</h2>
      <p class="section-sub">{stories.sub}</p>
    </div>

    <div class="reveal mt-12" data-testimonials>
      <div class="soft-card overflow-hidden p-6 md:p-10">
        {
          slides.map((t, i) => (
            <article
              class:list={[
                'testimonial-slide grid gap-8 md:grid-cols-[200px_minmax(0,1fr)] md:gap-10',
                i === 0 ? '' : 'hidden',
              ]}
              data-slide={i}
              aria-hidden={i === 0 ? 'false' : 'true'}
            >
              <div class="flex flex-col items-center gap-4 md:items-start">
                <img
                  src={t.image}
                  alt=""
                  width="180"
                  height="180"
                  class="h-36 w-36 rounded-full object-cover ring-1 ring-ink/5 md:h-[180px] md:w-[180px]"
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
                {
                  t.linkedin ? (
                    <a
                      href={t.linkedin}
                      rel="noopener"
                      target="_blank"
                      class="btn-ink w-fit !px-4 !py-2 text-xs"
                      data-linkedin
                    >
                      View LinkedIn profile →
                    </a>
                  ) : (
                    <span
                      class="inline-flex w-fit items-center rounded-full border border-dashed border-line px-4 py-2 text-xs font-medium text-faint"
                      data-linkedin-pending
                      title="LinkedIn URL pending"
                    >
                      LinkedIn soon
                    </span>
                  )
                }
              </div>
              <div class="flex min-w-0 flex-col justify-center">
                <span class="inline-flex w-fit items-center gap-2 rounded-full border border-line bg-paper-raised/80 px-3 py-1 text-xs font-medium text-soot">
                  <span class="h-1.5 w-1.5 rounded-full bg-hn-blue" aria-hidden="true" />
                  {t.badge}
                </span>
                <blockquote class="mt-5 font-serif text-[clamp(1.25rem,2.5vw,1.55rem)] leading-snug italic text-ink">
                  “{t.quote}”
                </blockquote>
                <div class="mt-6">
                  <p class="font-medium tracking-tight" data-name>{t.name}</p>
                  <p class="mt-0.5 text-sm text-gray" data-role>{t.role}</p>
                </div>
              </div>
            </article>
          ))
        }
        <div class="mt-8 flex items-center justify-end border-t border-line pt-6">
          <div class="flex items-center gap-1 rounded-full border border-line bg-paper-raised/80 p-1">
            <button
              type="button"
              class="flex h-8 w-8 items-center justify-center rounded-full text-soot transition-colors hover:bg-paper"
              data-prev
              aria-label="Previous testimonial"
            >
              ‹
            </button>
            <div class="flex items-center gap-1.5 px-1" role="tablist" aria-label="Testimonial slides">
              {
                slides.map((_, di) => (
                  <button
                    type="button"
                    class:list={['h-1.5 w-1.5 rounded-full transition-colors', di === 0 ? 'bg-ink' : 'bg-faint']}
                    data-dot={di}
                    aria-label={`Go to testimonial slide ${di + 1}`}
                    aria-current={di === 0 ? 'true' : undefined}
                  />
                ))
              }
            </div>
            <button
              type="button"
              class="flex h-8 w-8 items-center justify-center rounded-full text-soot transition-colors hover:bg-paper"
              data-next
              aria-label="Next testimonial"
            >
              ›
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="reveal mt-16">
      <p class="marker">{stories.examplesLabel}</p>
      <p class="mt-2 max-w-xl text-sm leading-relaxed text-gray">{stories.examplesIntro}</p>
      <ul class="mt-8 overflow-hidden rounded-[var(--radius-md)] border border-line bg-paper divide-y divide-line">
        {
          stories.startups.map((co) => (
            <li class="flex flex-col gap-1 px-5 py-4 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6 md:px-6">
              <div class="flex min-w-0 items-baseline gap-3">
                {'url' in co && co.url ? (
                  <a
                    href={co.url}
                    rel="noopener"
                    target="_blank"
                    class="text-base font-medium tracking-tight underline-offset-4 hover:underline"
                  >
                    {co.name}
                  </a>
                ) : (
                  <p class="text-base font-medium tracking-tight">{co.name}</p>
                )}
                <p class="shrink-0 text-xs font-medium uppercase tracking-[0.12em] text-gray">{co.tag}</p>
              </div>
              <p class="min-w-0 flex-1 text-sm leading-relaxed text-gray sm:text-right">{co.line}</p>
              <p class="shrink-0 text-xs font-medium text-soot sm:w-36 sm:text-right">{co.traction}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
<script>
  const root = document.querySelector('[data-testimonials]');
  if (root) {
    const slides = [...root.querySelectorAll<HTMLElement>('.testimonial-slide')];
    let index = 0;
    const show = (next: number) => {
      index = (next + slides.length) % slides.length;
      slides.forEach((slide, i) => {
        const on = i === index;
        slide.classList.toggle('hidden', !on);
        slide.setAttribute('aria-hidden', on ? 'false' : 'true');
      });
      root.querySelectorAll<HTMLElement>('[data-dot]').forEach((dot) => {
        const active = Number(dot.dataset.dot) === index;
        dot.classList.toggle('bg-ink', active);
        dot.classList.toggle('bg-faint', !active);
        if (active) dot.setAttribute('aria-current', 'true');
        else dot.removeAttribute('aria-current');
      });
    };
    root.querySelector('[data-prev]')?.addEventListener('click', () => show(index - 1));
    root.querySelector('[data-next]')?.addEventListener('click', () => show(index + 1));
    root.querySelectorAll<HTMLElement>('[data-dot]').forEach((dot) => {
      dot.addEventListener('click', () => show(Number(dot.dataset.dot)));
    });
  }
</script>
