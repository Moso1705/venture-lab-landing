---
import { partners } from '../content/site';
import SectionHead from './SectionHead.astro';
---

<section>
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    <SectionHead index="08" label={partners.eyebrow.replace(/^\/\s*/, '')} annotation="named, not implied">
      <h2 class="mt-10 max-w-2xl font-display text-3xl leading-tight text-paper md:text-4xl">
        {partners.headline}
      </h2>
    </SectionHead>

    <div class="reveal mt-12 flex flex-wrap gap-x-10 gap-y-5">
      {
        partners.orgs.map((org) => (
          <span class="font-sans text-xl font-semibold tracking-tight text-paper md:text-2xl">{org}</span>
        ))
      }
    </div>

    <p class="reveal mt-10 max-w-prose text-base leading-relaxed text-fog">{partners.ewor}</p>

    <div class="reveal mt-12 border-t border-line pt-6">
      <p class="font-mono text-[0.75rem] tracking-[0.08em] text-fog-dim">
        / mba coaches come from
      </p>
      <p class="mt-3 font-mono text-[0.8125rem] leading-relaxed tracking-[0.02em] text-fog">
        {partners.schools.join(' · ')}
      </p>
    </div>
  </div>
</section>
