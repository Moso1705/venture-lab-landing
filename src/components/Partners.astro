---
import { readFile } from 'node:fs/promises';
import { join } from 'node:path';
import { partners } from '../content/site';
import SectionHead from './SectionHead.astro';

// Inline the SVGs: four of them color via currentColor, which an <img> cannot
// inherit (isolated document resolves it to black on our dark background).
// Resolved from cwd because import.meta.url points into dist during prerender.
const logos = await Promise.all(
  partners.orgs.map(async (org) => ({
    ...org,
    svg: await readFile(join(process.cwd(), 'public', org.logo), 'utf8'),
  }))
);
---

<section>
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    <SectionHead index="08" label={partners.eyebrow.replace(/^\/\s*/, '')} annotation="named, not implied">
      <h2 class="mt-10 max-w-2xl font-display text-3xl leading-tight text-paper md:text-4xl">
        {partners.headline}
      </h2>
    </SectionHead>

    <!-- currentColor logos inherit paper; AWS/Databricks ship pre-colored for dark. -->
    <div class="reveal mt-12 flex flex-wrap items-center gap-x-12 gap-y-8 text-paper">
      {
        logos.map((org) => (
          <a
            href={org.href}
            target="_blank"
            rel="noopener"
            class="logo-slot opacity-65 transition-opacity duration-200 hover:opacity-100"
            aria-label={org.name}
            style={`--logo-h: ${org.h}px`}
            set:html={org.svg}
          />
        ))
      }
    </div>

    <p class="reveal mt-10 max-w-prose text-base leading-relaxed text-fog">{partners.ewor}</p>

    <div class="reveal mt-12 border-t border-line pt-6">
      <p class="font-mono text-[0.75rem] tracking-[0.08em] text-fog-dim">
        / mba coaches come from
      </p>
      <p class="mt-3 font-mono text-[0.8125rem] leading-relaxed tracking-[0.02em] text-fog">
        {partners.schools.join(' · ')}
      </p>
    </div>
  </div>
</section>

<style>
  .logo-slot :global(svg) {
    height: var(--logo-h, 24px);
    width: auto;
    display: block;
  }
</style>
