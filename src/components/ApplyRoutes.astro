---
/**
 * Three applicant paths. Differentiated tones (primary / soft blue / raised).
 * Founders: soft blue wash + strong HN-Blue border/CTA (most prominent, not solid fill).
 * Mentors: soft blue. MBA: quiet white.
 */
import { applyRoutes } from '../content/site';
---

<section class="band-raised border-b border-line">
  <div class="mx-auto max-w-6xl px-6 py-16 md:px-8 md:py-20">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="marker">{applyRoutes.marker}</p>
      <h2 class="section-title mt-3 italic">{applyRoutes.headline}</h2>
      <p class="section-sub">{applyRoutes.sub}</p>
    </div>

    <div class="reveal mt-10 grid gap-4 md:grid-cols-3 md:gap-5">
      {
        applyRoutes.paths.map((path) => (
          <a
            href={path.href}
            class:list={[
              'group flex flex-col rounded-[var(--radius-md)] p-6 transition-[transform,box-shadow,background-color,border-color] duration-200 md:p-8',
              path.tone === 'ink' &&
                'border-2 border-hn-blue bg-hn-blue-soft text-ink shadow-[var(--shadow-primary)] hover:bg-[color-mix(in_srgb,var(--color-hn-blue)_14%,white)]',
              path.tone === 'blue' &&
                'border border-hn-blue/25 bg-hn-blue-soft/70 shadow-[var(--shadow-soft)] hover:border-hn-blue/40',
              path.tone === 'raised' &&
                'border border-ink/10 bg-paper shadow-[var(--shadow-soft)] hover:border-ink/20',
            ]}
          >
            <p
              class:list={[
                'text-xs font-medium uppercase tracking-[0.14em]',
                path.tone === 'ink' && 'text-hn-blue',
                path.tone === 'blue' && 'text-hn-blue',
                path.tone === 'raised' && 'text-gray',
              ]}
            >
              {path.role}
            </p>
            <h3 class="mt-4 font-serif text-[1.5rem] leading-snug tracking-tight md:text-[1.65rem]">
              {path.title}
            </h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-gray">
              {path.body}
            </p>
            <span
              class:list={[
                'mt-8 inline-flex items-center gap-2 text-sm font-medium',
                path.tone === 'ink' && 'text-hn-blue',
                path.tone === 'blue' && 'text-hn-blue',
                path.tone === 'raised' && 'text-ink',
              ]}
            >
              {path.cta}
              <span class="transition-transform duration-200 group-hover:translate-x-0.5" aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
