---
/**
 * Proof in three registers: the aggregate numbers big and bare, the Anto
 * seed-round story as the featured statement, and founder quotes set huge,
 * speedrun-style. More quotes render automatically as Michi approves them.
 */
import { proof } from '../content/site';
---

<section id="proof" class="border-t border-line">
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
    <p class="marker reveal">{proof.marker}</p>
    <h2 class="display reveal mt-6 text-[clamp(2.25rem,4.5vw,3.5rem)]">{proof.headline}</h2>

    <div class="reveal mt-14 grid grid-cols-2 gap-y-12 md:grid-cols-5">
      {
        proof.stats.map((stat, i) => (
          <div class={`pr-6 ${i > 0 ? 'md:border-l md:border-line md:pl-8' : ''} ${i % 2 === 1 ? 'border-l border-line pl-8 md:pl-8' : ''}`}>
            <p class="display text-[clamp(2.5rem,4vw,3.5rem)] tabular-nums" data-countup={stat.value} data-suffix={stat.suffix}>
              {stat.value.toLocaleString('en-US')}{stat.suffix}
            </p>
            <p class="mt-3 text-[0.875rem] leading-snug text-gray">{stat.label}</p>
          </div>
        ))
      }
    </div>

    <p class="reveal mt-12 flex items-center gap-3 font-mono text-[0.75rem] uppercase tracking-[0.16em] text-soot">
      <span class="live-dot inline-block h-1.5 w-1.5 rounded-full bg-phoenix" aria-hidden="true"></span>
      {proof.live}
    </p>

    <div class="reveal mt-20 border-t border-line pt-12 md:mt-24">
      <p class="font-mono text-[0.75rem] uppercase tracking-[0.18em] text-phoenix">{proof.featured.kicker}</p>
      <p class="display mt-5 max-w-3xl text-[clamp(2rem,4vw,3.25rem)]">{proof.featured.title}</p>
      <p class="mt-5 max-w-2xl text-[1.0625rem] leading-relaxed text-gray">{proof.featured.body}</p>
    </div>

    {
      proof.quotes.map((quote) => (
        <figure class="reveal mt-20 border-t border-line pt-12 md:mt-24">
          <blockquote class="display max-w-4xl text-[clamp(1.75rem,3.5vw,2.75rem)]">
            <span class="text-faint" aria-hidden="true">“</span>{quote.text}<span class="text-faint" aria-hidden="true">”</span>
          </blockquote>
          <figcaption class="mt-6 font-mono text-[0.8125rem] uppercase tracking-[0.16em] text-gray">
            {quote.name} · {quote.role}
          </figcaption>
        </figure>
      ))
    }
  </div>
</section>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .live-dot {
      animation: live-pulse 2.4s ease-in-out infinite;
    }
    @keyframes live-pulse {
      50% {
        opacity: 0.3;
      }
    }
  }
</style>
